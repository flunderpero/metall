struct Planet {
    name Str
    diameter Int
}

fun make_earth() Planet {
    Planet("Earth", 12500)
}

fun print_planet(p Planet) void {
    print_str(p.name)
    print_int(p.diameter)
}

fun main() void {
    mut earth = make_earth()
    print_planet(earth)

    earth.name = "Mother"
    earth.diameter = 12742
    print_planet(earth)
}
