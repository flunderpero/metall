    }
}

--- Draw textured triangles sampling `t`. Vertices' tex_coords are in 0..1. ---
pub fun Renderer.geometry_textured(r Renderer, t Texture, vertices []Vertex) void {
    if not unsafe render_geometry_(r.handle, t.handle, ffi.slice_ptr(vertices), vertices.len.to_i32_clamped(), ffi.Ptr.null<I32>(), I32(0)) {
        -- Can only fail on an invalid renderer/texture/args, ruled out by our types.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

