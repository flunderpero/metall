use std.ffi
use std.io
use std.fs
use std.enums

pub enum SDLErr Err = 
    | init_failed 
    | create_window_failed 
    | raise_window_failed
    | set_window_fullscreen_failed
    | create_renderer_failed
    | set_render_vsync_failed
    | load_bmp_failed
    | create_texture_failed
    | render_read_pixels_failed
    | save_bmp_failed
    | load_wav_failed
    | open_audio_device_stream_failed

pub enum InitFlags U32 =
    | audio = 0x00000010
    | video = 0x00000020
    | events = 0x00004000


--- Bring SDL and the given subsystems up. ---
pub fun init(flags U32) !void {
    if not unsafe init_(flags) {
        return SDLErr.init_failed
    }
}

--- Shut SDL down, releasing everything `init` brought up. ---
pub fun quit() void {
    unsafe quit_()
}

--- Milliseconds since SDL was initialized. ---
pub fun ticks() Int {
    unsafe get_ticks_()
}

--- A high-resolution counter value, in ticks. Divide a difference of two
    readings by `performance_frequency()` to get elapsed seconds. ---
pub fun performance_counter() Int {
    unsafe get_performance_counter_()
}

--- Ticks per second of `performance_counter()`. ---
pub fun performance_frequency() Int {
    unsafe get_performance_frequency_()
}

pub fun error(@a Arena) Str {
    let cstr = unsafe get_error_()
    let bytes = unsafe ffi.from_cstr(cstr)
    Str.from_utf8_lossy(bytes, @a)
}

fun sdl_panic_message(@a Arena) Str {
    f"SDLError: {error(@a)}".build(@a)
}

pub struct Window {
    handle ffi.Ptr<void>
}

--- Create a centered window of the given size. 

    `flags` is a bitmask of SDL's `SDL_WINDOW_*` constants (0 for a plain window). ---
pub fun Window.create(title Str, w I32, h I32, flags U64 = 0) !Window {
    let @local = Arena()
    let title = ffi.cstr(title.as_bytes(), @local)
    let handle = unsafe create_window_(title, w, h, flags)
    if handle.is_null() {
        return SDLErr.create_window_failed
    }
    Window(handle)
}

--- Destroy a window. ---
pub fun Window.destroy(w Window) void {
    unsafe destroy_window_(w.handle)
}

pub fun Window.raise(w Window) !void {
    if not unsafe raise_window_(w.handle) {
        return SDLErr.raise_window_failed
    }
}

--- Switch the window between borderless fullscreen-desktop and windowed. ---
pub fun Window.set_fullscreen(w Window, fullscreen Bool) !void {
    if not unsafe set_window_fullscreen_(w.handle, fullscreen) {
        return SDLErr.set_window_fullscreen_failed
    }
}

--- A handle to a raw SDL_Event buffer. ---
pub struct SDLEvent {
    handle ffi.PtrMut<void>
}

enum EventType U32 = 
    | key_down = 0x300 
    | key_up = 0x301 
    | mouse_motion = 0x400
    | mouse_button_down = 0x401
    | mouse_button_up = 0x402

pub struct KeyEvent {
    pub scancode U32
    pub key U32
    pub mod U16
    pub down Bool
    pub repeat Bool
}

pub fun KeyEvent.fmt(e KeyEvent, sw &mut StrWriter) void {
    f"KeyEvent(\
        scancode={e.scancode}, key={e.key}, key_rune={Rune.from_u32_lossy(e.key)}, \
        mod={e.mod}, down={e.down}, repeat={e.repeat})".write_to(sw)
}

pub enum MouseButton U8 = left = 1 | middle = 2 | right = 3 | x1 = 4 | x2 = 5

pub struct MouseMotionEvent {
    pub state U32
    pub x F32
    pub y F32
    pub xrel F32
    pub yrel F32
}

pub fun MouseMotionEvent.fmt(e MouseMotionEvent, sw &mut StrWriter) void {
    f"MouseMotionEvent(state={e.state}, x={e.x}, y={e.y}, xrel={e.xrel}, yrel={e.yrel})".write_to(sw)
}

pub struct MouseButtonEvent {
    pub button MouseButton
    pub down Bool
    pub clicks U8
    pub x F32
    pub y F32
}

pub fun MouseButtonEvent.fmt(e MouseButtonEvent, sw &mut StrWriter) void {
    f"SDLMouseButtonEvent(button={e.button.debug_name}, down={e.down}, clicks={e.clicks}, x={e.x}, y={e.y})".write_to(sw)
}

pub union Event = KeyEvent | MouseMotionEvent | MouseButtonEvent

pub fun Event.fmt(e Event, sw &mut StrWriter) void {
    match e {
    case KeyEvent e: e.fmt(sw)
    case MouseMotionEvent e: e.fmt(sw)
    case MouseButtonEvent e: e.fmt(sw)
    }
}

pub fun pump_events() void {
    unsafe pump_events_()
}

--- Poll events and convert them to "Metall" events.

    We cannot convert SDL_Event directly because it is a C union and there
    is no uniform way to convert a C union to a Metall union.

    If `renderer` is given, its `.convert_event_coords()` is called first. ---
pub fun poll_event(renderer ?Renderer, @a Arena) ?Event {
    -- Mirror the SDL_Event member structs so we can cast the raw buffer. Field
    -- order must match SDL's C ABI. reserved/raw/padding are layout filler.
    struct SDLKeyboardEvent {
        type U32
        reserved U32
        timestamp U64
        window_id U32
        which U32
        scancode U32
        key U32
        mod U16
        raw U16
        down Bool
        repeat Bool
    }

    struct SDLMouseMotionEvent {
        type U32
        reserved U32
        timestamp U64
        window_id U32
        which U32
        state U32
        x F32
        y F32
        xrel F32
        yrel F32
    }

    struct SDLMouseButtonEvent {
        type U32
        reserved U32
        timestamp U64
        window_id U32
        which U32
        button U8
        down Bool
        clicks U8
        padding U8
        x F32
        y F32
    }

    mut buf = (unsafe [16 uninit U64])[..]
    let ptr = unsafe ffi.slice_ptr_mut(buf).cast_ptr<void>()
    if not unsafe poll_event_(ptr) {
        return None()
    }
    match renderer {
        case None:
        else r: r.convert_event_coords(SDLEvent(ptr))
    }
    let type = unsafe (unsafe ptr.cast_ptr<U32>()).read()
    when {
    case type == EventType.key_up.tag or type == EventType.key_down.tag:
        let e = unsafe (unsafe ptr.cast_ptr<SDLKeyboardEvent>()).read()
        return Event(KeyEvent(
            scancode=e.scancode,
            key=e.key,
            mod=e.mod,
            down=e.down,
            repeat=e.repeat
        ))
    case type == EventType.mouse_motion.tag:
        let e = unsafe (unsafe ptr.cast_ptr<SDLMouseMotionEvent>()).read()
        return Event(MouseMotionEvent(
            state=e.state,
            x=e.x,
            y=e.y,
            xrel=e.xrel,
            yrel=e.yrel
        ))
    case type == EventType.mouse_button_down.tag or type == EventType.mouse_button_up.tag:
        let e = unsafe (unsafe ptr.cast_ptr<SDLMouseButtonEvent>()).read()
        match enums.from_tag<MouseButton>(e.button) {
        case None:
        else button:
            return Event(MouseButtonEvent(
                button=button,
                down=e.down,
                clicks=e.clicks,
                x=e.x,
                y=e.y
            ))
        }
    else:
    }
    None()
}

pub struct Color {
    pub r U8
    pub g U8
    pub b U8
    pub a U8
}

pub struct FColor {
    pub r F32
    pub g F32
    pub b F32
    pub a F32
}

pub struct FPoint {
    pub x F32
    pub y F32
}

pub struct FRect {
    pub x F32
    pub y F32
    pub w F32
    pub h F32
}

pub enum BlendMode U32 =
    | none = 0x00000000
    | blend = 0x00000001
    | blend_premultiplied = 0x00000010
    | add = 0x00000002
    | add_premultiplied = 0x00000020
    | mod = 0x00000004
    | mul = 0x00000008

pub enum ScaleMode I32 =
    | nearest = 0
    | linear = 1
    | pixelart = 2

pub struct Vertex {
    pub pos FPoint
    pub color FColor
    pub tex_coord FPoint
}

pub fun Vertex.translate(v Vertex, x F32, y F32) Vertex {
    Vertex(FPoint(v.pos.x + x, v.pos.y + y), v.color, v.tex_coord)
}

pub struct Renderer {
    handle ffi.Ptr<void>
}

--- Create a 2D renderer for the window. 

    `name` picks a driver or - if absent - lets SDL choose. ---
pub fun Window.create_renderer(w Window, name ?Str = None()) !Renderer {
    let @local = Arena()
    let name = match name {
        case None: ffi.Ptr.null<U8>()
        else s: ffi.cstr(s.as_bytes(), @local)
    }
    let handle = unsafe create_renderer_(w.handle, name)
    if handle.is_null() {
        return SDLErr.create_renderer_failed
    }
    Renderer(handle)
}

pub fun Renderer.destroy(r Renderer) void {
    unsafe destroy_renderer_(r.handle)
}

pub fun Renderer.set_draw_color(r Renderer, c Color) void {
    if not unsafe set_render_draw_color_(r.handle, c.r, c.g, c.b, c.a) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun Renderer.clear(r Renderer) void {
    if not unsafe render_clear_(r.handle) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun Renderer.present(r Renderer) void {
    if not unsafe render_present_(r.handle) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub enum RendererVsync I32 = 
