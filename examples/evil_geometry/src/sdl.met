pub enum LogicalPresentation I32 =
    | disabled = 0
    | stretch = 1
    | letterbox = 2
    | overscan = 3
    | integer_scale = 4

--- Set a virtual resolution to render in. SDL scales and letterboxes it onto the real window. ---
pub fun Renderer.set_logical_presentation(r Renderer, w I32, h I32, mode LogicalPresentation) void {
    if not unsafe set_render_logical_presentation_(r.handle, w, h, mode.tag) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

--- Rewrite an event's mouse and touch coordinates from window pixels into logical coordinates, in place. ---
pub fun Renderer.convert_event_coords(r Renderer, event SDLEvent) void {
    if not unsafe convert_event_to_render_coordinates_(r.handle, event.handle) {
        -- Can only fail on an invalid renderer or event, both ruled out here.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub struct Texture {
    handle ffi.Ptr<void>
}

--- Load a BMP file into a texture for the given renderer. ---
pub fun Texture.load_bmp(path fs.Path, r Renderer) !Texture {
    let @local = Arena()
    let surface = unsafe load_bmp_(ffi.cstr(path.as_bytes(), @local))
    if surface.is_null() {
        return SDLErr.load_bmp_failed
    }
    let handle = unsafe create_texture_from_surface_(r.handle, surface)
    unsafe destroy_surface_(surface)
    if handle.is_null() {
        return SDLErr.load_bmp_failed
    }
    Texture(handle)
}

pub fun Texture.destroy(t Texture) void {
    unsafe destroy_texture_(t.handle)
}

--- Draw the whole texture into `dst`. ---
pub fun Renderer.texture(r Renderer, t Texture, dst FRect) void {
    if not unsafe render_texture_(r.handle, t.handle, ffi.Ptr.null<FRect>(), ffi.ref_ptr(&dst)) {
        -- Can only fail on an invalid renderer/texture, ruled out by our types.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

--- Create an empty texture to render into (a render target). ---
pub fun Texture.create_target(r Renderer, w I32, h I32) !Texture {
    -- SDL_PIXELFORMAT_RGBA8888, SDL_TEXTUREACCESS_TARGET
    let handle = unsafe create_texture_(r.handle, 0x16462004, 2, w, h)
    if handle.is_null() {
        return SDLErr.create_texture_failed
    }
    Texture(handle)
}

pub fun Texture.set_blend_mode(t Texture, mode BlendMode) void {
    if not unsafe set_texture_blend_mode_(t.handle, mode.tag) {
        -- Can only fail on an invalid texture, ruled out by our typed Texture.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun Texture.set_scale_mode(t Texture, mode ScaleMode) void {
    if not unsafe set_texture_scale_mode_(t.handle, mode.tag) {
        -- Can only fail on an invalid texture, ruled out by our typed Texture.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun Texture.set_color_mod(t Texture, r U8, g U8, b U8) void {
    if not unsafe set_texture_color_mod_(t.handle, r, g, b) {
        -- Can only fail on an invalid texture, ruled out by our typed Texture.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun Texture.set_alpha_mod(t Texture, a U8) void {
    if not unsafe set_texture_alpha_mod_(t.handle, a) {
        -- Can only fail on an invalid texture, ruled out by our typed Texture.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

--- Send subsequent drawing into `target` instead of the window. ---
pub fun Renderer.set_target(r Renderer, target Texture) void {
    if not unsafe set_render_target_(r.handle, target.handle) {
        -- Fails only if `target` was not created with `create_target`.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

--- Restore drawing to the window. ---
pub fun Renderer.reset_target(r Renderer) void {
    if not unsafe set_render_target_(r.handle, ffi.Ptr.null<void>()) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

--- Save the current render target to a BMP file. For debugging. ---
pub fun Renderer.save_target(r Renderer, path fs.Path) !void {
    let @local = Arena()
    let surf = unsafe render_read_pixels_(r.handle, ffi.Ptr.null<void>())
    if surf.is_null() {
        return SDLErr.render_read_pixels_failed
    }
    if not unsafe save_bmp_(surf, ffi.cstr(path.as_bytes(), @local)) {
        unsafe destroy_surface_(surf)
        return SDLErr.save_bmp_failed
    }
    unsafe destroy_surface_(surf)
}

-- Width and height in pixels of one `Renderer.debug_text` character at scale 1.
pub let debug_text_char_size F32 = 8.0

--- Draw `text` at (x, y) in the current draw color using SDL's built-in 8x8
    debug font. Enlarge it with `Renderer.set_scale`. ---
pub fun Renderer.debug_text(r Renderer, x F32, y F32, text Str) void {
    let @local = Arena()
    let cstr = ffi.cstr(text.as_bytes(), @local)
    if not unsafe render_debug_text_(r.handle, x, y, cstr) {
        -- Can only fail on an invalid renderer or font-atlas allocation.
        panic(sdl_panic_message(@local))
    }
}

--- Scale all subsequent drawing by (sx, sy). Handy for enlarging `debug_text`. ---
pub fun Renderer.set_scale(r Renderer, sx F32, sy F32) void {
    if not unsafe set_render_scale_(r.handle, sx, sy) {
        -- Can only fail on an invalid renderer, ruled out by our typed Renderer.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

-- SDL3/SDL_audio.h

pub enum AudioFormat I32 =
    | unknown = 0x0000
    | u8 = 0x0008
    | s8 = 0x8008
    | s16le = 0x8010
    | s16be = 0x9010
    | s32le = 0x8020
    | s32be = 0x9020
    | f32le = 0x8120
    | f32be = 0x9120

pub struct AudioSpec {
    pub format AudioFormat
    pub channels I32
    pub freq I32
}

pub nocopy struct AudioBuf {
    pub spec AudioSpec
    audio_buf ffi.Ptr<void>
    audio_len I32
}

pub fun AudioBuf.load_wav(path fs.Path, @a Arena) !&AudioBuf {
    let buf = @a.new(AudioBuf(
        spec=AudioSpec(AudioFormat.unknown, I32(0), I32(0)),
        audio_buf=ffi.Ptr.null<void>(),
        audio_len=0
    ))
    let @local = Arena()
    if not unsafe load_wav_(
        path=ffi.cstr(path.as_bytes(), @local),
        spec=ffi.ref_ptr_mut(&mut buf.spec),
        audio_buf=ffi.ref_ptr_mut(&mut buf.audio_buf),
        audio_len=unsafe ffi.ref_ptr_mut(&mut buf.audio_len).cast_ptr<U32>()) {
        return SDLErr.load_wav_failed
    }
    buf
}

--- Convert the fiven audio to the given spec.

    Note: The source audio is not destroyed. ---
pub fun AudioBuf.convert(a &AudioBuf, spec AudioSpec, @a Arena) !&AudioBuf {
    let new = @a.new(AudioBuf(spec=spec, audio_buf=ffi.Ptr.null<void>(), audio_len=0))
    if not unsafe convert_audio_samples_(
        src_spec=ffi.ref_ptr(&a.spec),
        src_data=a.audio_buf,
        src_len=a.audio_len,
        dst_spec=ffi.ref_ptr(&spec),
        dst_data=ffi.ref_ptr_mut(&mut new.audio_buf),
        dst_len=ffi.ref_ptr_mut(&mut new.audio_len)) {
        -- Can only fail on an invalid spec (ruled out by our types) or OOM.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
    new
}

pub fun AudioBuf.destroy(a &AudioBuf) void {
    unsafe free_(unsafe a.audio_buf.cast_ptr<void>())
}

pub struct AudioDeviceStream {
    handle ffi.Ptr<void>
}

pub fun AudioDeviceStream.open(spec AudioSpec) !AudioDeviceStream {
    -- 0xFFFFFFFF is SDL_AUDIO_DEVICE_DEFAULT_PLAYBACK
    let handle = unsafe open_audio_device_stream_(
        devid=0xFFFFFFFF, 
        spec=ffi.ref_ptr(&spec),
        callback=ffi.Ptr.null<void>(),
        userdata=ffi.Ptr.null<void>())
    if handle.is_null() {
        return SDLErr.open_audio_device_stream_failed
    }
    if not unsafe resume_audio_stream_device_(handle) {
        -- The stream was just opened, so resume can only fail on OOM.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
    AudioDeviceStream(handle)
}

pub fun AudioDeviceStream.play(s AudioDeviceStream, buf &AudioBuf) void {
    if not unsafe put_audio_stream_data_(s.handle, buf.audio_buf, buf.audio_len) {
        -- Can only fail on an invalid stream/buffer (ruled out by our types) or OOM.
        let @local = Arena()
        panic(sdl_panic_message(@local))
    }
}

pub fun AudioDeviceStream.get_queued(s AudioDeviceStream) I32 {
    let res = unsafe get_audio_stream_queued_(s.handle)
    if res == -1 {
        panic("get_audio_stream_queued returned -1")
    }
    return res
}

pub fun AudioDeviceStream.destroy(s AudioDeviceStream) void {
    unsafe destroy_audio_stream_(s.handle)
}

