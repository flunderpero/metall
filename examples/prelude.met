--- Just test that the full prelude is available
---

struct Value<T ToStr> {
    value T
}

fun Value.to_str<T ToStr>(v Value<T>, @a Arena) Str { v.value.to_str(@a) }

fun main() void {
    let @a = Arena()
    let s = "Hello".concat(" there", @a)
    print_str(s)

    let v = Value<Str>("to_str")
    print_str(v.to_str(@a))
}
