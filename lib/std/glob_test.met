shape Sut {
    fun Sut.yes(s Sut, pattern Str, paths []Str) !void 
    fun Sut.non(s Sut, pattern Str, paths []Str) !void 
}

#if not os.wasm

struct GitSut {
    dir fs.Path
}

fun GitSut.new() !GitSut {
    let @local = Arena()
    let dir = { 
        let mktemp = try os.shell_output(["mktemp", "-d"][..], @local) 
        fs.Path.from_str(mktemp.trim())
    }
    try os.chdir(dir)
    try os.shell_checked(["git", "init"][..], @local)
	-- Tell Git to treat paths as case-sensitive..
    try os.shell_checked(["git", "config", "core.ignorecase", "false"][..], @local)
	-- Tell Git to print unicode characters as-is.
	try os.shell_checked(["git", "config", "core.quotepath", "false"][..], @local)
    for i in 0..paths.len {
        let full_path = dir.join(fs.Path.from_str(paths[i]), @local)
    }
    GitSut(dir)
}

fun GitSut.close() void {
    
}

