---
func (g *gitGlobTester) check(pattern string, paths ...string) []string {
	assert := NewAssert(g.tb)
	err := os.WriteFile(filepath.Join(g.dir, ".gitignore"), []byte(pattern), 0o600)
	assert.NoError(err, "Failed to write .gitignore")

	matches := []string{}
	for _, path := range paths {
		cmd := exec.Command("git", "check-ignore", path)
		cmd.Dir = g.dir
		err = cmd.Run()
		switch cmd.ProcessState.ExitCode() {
		case 0:
			matches = append(matches, path)
		case 1:
		default:
			g.tb.Fatalf(
				"git check-ignore failed: expected no error, got exit status %d: %v",
				cmd.ProcessState.ExitCode(),
				err,
			)
		}
	}
	return matches
}
---

#end

fun test_happy_path<S Sut>(sut S) !void {
}

fun main() void {
    let @local = Arena()
    let suite = test.Suite.new("match", @local)
    suite.test("pattern", fun() !void {
        let @local = Arena()
        try test.eq("abc", Str.from_utf8_lossy(glob.Pattern.new("abc ").text, @local))
    })

    #if not os.wasm
    let git_sut = try GitSut.new() else e { io.println("failed to create git_sut") return void }
    suite.test("happy_path", fun[&git_sut]() !void {
        try test_happy_path(git_sut)
    })
    #end

    _ = suite.run()
}
