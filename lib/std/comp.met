struct BoolType {}
struct StrType {}
struct VoidType {}

struct IntType {
    name Str
    signed Bool
    bits Int
}

struct Field {
    name Str
    typ &Type
    is_mut Bool
}

struct StructType {
    name Str
    fields []Field
}

union Type = BoolType | StrType | VoidType | IntType | StructType

fun type_of<T>() Type {
    panic("comp::type_of must only be used as a macro argument")
    StrType()
}
