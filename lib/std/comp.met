struct BoolType {}
struct StrType {}
struct VoidType {}
struct NeverType {}

struct IntType {
    name Str
    signed Bool
    bits Int
}

struct Field {
    name Str
    typ &Type
    is_mut Bool
}

struct StructType {
    name Str
    fields []Field
}

struct UnionType {
    name Str
    variants []&Type
}

union Type = BoolType | StrType | VoidType | NeverType | IntType | StructType | UnionType

fun type_of<T>() Type {
    panic("comp::type_of must only be used as a macro argument")
}
