use std::test
use std::set

fun main() void {
    let @local = Arena()
    let suite = test::Suite.new("Set", @local)
    suite.test("happy path", fun() !void {
        let @local = Arena()
        let sut = set::Set.new<Int>(4, @local)
        try test::eq(0, sut.len())

        sut.add(1)
        try test::eq(1, sut.len())
        try test::eq(true, sut.has(1))
        try test::eq(false, sut.has(2))

        sut.add(2)
        try test::eq(2, sut.len())
        try test::eq(true, sut.has(1))
        try test::eq(true, sut.has(2))

        try test::eq(true, sut.del(1))
        try test::eq(1, sut.len())
        try test::eq(false, sut.has(1))
        try test::eq(true, sut.has(2))
    })
    _ = suite.run()
}

