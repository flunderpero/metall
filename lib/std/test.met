--- A testing framework. ---

use std::list
use std::io

struct Test {
    name Str
    f fun() !void
}

struct Suite {
    name Str
    mut bail Bool
    tests &mut list::List<Test>
}

fun Suite.new(name Str, @a Arena) &mut Suite {
    @a.new_mut<Suite>(Suite(name, false, list::List.new<Test>(@a)))
}

struct SuiteResult {
    succeeded Int
    failed Int
}

fun Suite.test(s &mut Suite, name Str, f fun() !void) void {
    s.tests.push(Test(name, f))
}

fun Suite.run(s &mut Suite) SuiteResult {
    let @local = Arena()
    mut failed = 0
    for test_index in 0..s.tests.len {
        let test = s.tests.get(test_index)
        let prefix = {
            let sb = StrBuilder.new(32, @local)
            sb.str(s.name)
            sb.str("(")
            sb.int(test_index + 1)
            sb.str("/")
            sb.int(s.tests.len)
            sb.str(") ")
            sb.tab()
            sb.str(test.name)
            sb.to_str() 
        }
        io::println(prefix)
        match test.f() {
            case Err e: 
                failed = failed + 1
                io::print(prefix)
                io::println(" \x1b[31mFAILED\x1b[0m")
                if s.bail {
                    return SuiteResult(test_index - 1, failed)
                }
            else: 
        }
    }
    SuiteResult(s.tests.len - failed, failed)
}

let assertion_failed_err = Err("assertion failed")

shape HasEqFmt {
    fun HasEqFmt.eq(e HasEqFmt, other HasEqFmt) Bool
    fun HasEqFmt.fmt(e HasEqFmt, sb &mut StrBuilder) void
}

fun ok(b Bool, msg Str = "") !void { 
    if not b { 
        private_print_assert_err_msg(msg, "want: true, got: false")
        return assertion_failed_err
    }
}

fun not_ok(b Bool, msg Str = "") !void { 
    if b { 
        private_print_assert_err_msg(msg, "want: false, got: true")
        return assertion_failed_err
    }
}

fun contains_str(haystack Str, needle Str, msg Str = "") !void {
    if not haystack.contains(needle) {
        let @local = Arena()
        let sb = StrBuilder.new(32, @local)
        sb.str("want '")
        sb.str(haystack)
        sb.str("' to contain '")
        sb.str(needle)
        sb.str("'")
        private_print_assert_err_msg(msg, sb.to_str())
        return assertion_failed_err
    }
}

fun eq<T HasEqFmt>(want T, got T, msg Str = "") !void {
    if not want.eq(got) {
        let @local = Arena()
        let sb = StrBuilder.new(32, @local)
        sb.str("want ")
        sb.fmt<T>(want)
        sb.str(", got ")
        sb.fmt<T>(got)
        private_print_assert_err_msg(msg, sb.to_str())
        return assertion_failed_err
    }
}

fun neq<T HasEqFmt>(want T, got T, msg Str = "") !void {
    if want.eq(got) {
        let @local = Arena()
        let sb = StrBuilder.new(32, @local)
        sb.str("want ")
        sb.fmt<T>(want)
        sb.str("not to equal ")
        sb.fmt<T>(got)
        private_print_assert_err_msg(msg, sb.to_str())
        return assertion_failed_err
    }
}

