fun err<T>(obj !T, err_msg_contains Str, msg Str = "") !void {
    match obj {
        case Err e: 
            if not e.msg.contains(err_msg_contains) {
        let @local = Arena()
        let sb = StrBuilder.new(32, @local)
                sb.str("want error to contain '")
                sb.str(err_msg_contains)
                sb.str("', but got: ")
                sb.str(e.msg)
                private_print_assert_err_msg(msg, sb.to_str())
                return assertion_failed_err
            }
        else: 
            private_print_assert_err_msg(msg, "want an error")
            return assertion_failed_err
    }
}

fun private_print_assert_err_msg(user_provided Str, err Str) void {
    let @local = Arena()
    io::print("\x1b[31m")
    if user_provided.is_empty() {
        io::print(err)
        io::println("\x1b[0m")
        return void
    }
    let sb = StrBuilder.new(user_provided.bytes_len() + err.bytes_len() + 3, @local)
    sb.str(user_provided)
    sb.str(" (")
    sb.str(err)
    sb.str(")")
    sb.str("\x1b[0m")
    io::println(sb.to_str())
}
