pub fun lte_u64(left U64, right U64, msg Str = "") !void {
    if not (left <= right) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {left} <= {right}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun err<T>(obj !T, expected Err, msg Str = "") !void {
    match obj {
        case Err e if e == expected: 
        case Err e if e != expected: 
            let @local = Arena()
            print_assert_err_msg(msg, f"want error to be '{expected.debug_name}', but got '{e.debug_name}'".build(@local))
            return AssertErr.mismatch
        else: 
            print_assert_err_msg(msg, "want an error")
            return AssertErr.not_an_error
    }
}

fun print_assert_err_msg(user_provided Str, err Str) void {
    let @local = Arena()
    io.print("\x1b[31m")
    if user_provided.is_empty() {
        io.print(err)
        io.println("\x1b[0m")
        return void
    }
    io.println(f"{user_provided} ({err})\x1b[0m".build(@local))
}
