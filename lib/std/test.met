pub fun err<T>(obj !T, expected Err, msg Str = "") !void {
    match obj {
        case Err e if e == expected: 
        case Err e if e != expected: 
            let @local = Arena()
            let sb = StrBuilder.new(32, @local)
            sb.str("want error to be '")
            sb.str(expected.debug_name)
            sb.str("', but got: ")
            sb.str(e.debug_name)
            print_assert_err_msg(msg, sb.as_str())
            return AssertErr.mismatch
        else: 
            print_assert_err_msg(msg, "want an error")
            return AssertErr.not_an_error
    }
}

fun print_assert_err_msg(user_provided Str, err Str) void {
    let @local = Arena()
    io.print("\x1b[31m")
    if user_provided.is_empty() {
        io.print(err)
        io.println("\x1b[0m")
        return void
    }
    let sb = StrBuilder.new(user_provided.bytes_len() + err.bytes_len() + 3, @local)
    sb.str(user_provided)
    sb.str(" (")
    sb.str(err)
    sb.str(")")
    sb.str("\x1b[0m")
    io.println(sb.as_str())
}
