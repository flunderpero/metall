--- A testing framework. ---
use std.list.List
use std.io

struct Test {
    name Str
    f fun() !void
}

pub struct Suite {
    name Str
    bail Bool
    tests &mut List<Test>
}

pub fun Suite.new(name Str, @a Arena) &mut Suite {
    @a.new<Suite>(Suite(name, false, List.new<Test>(32, @a)))
}

pub struct SuiteResult {
    pub succeeded Int
    pub failed Int
}

pub fun Suite.test(s &mut Suite, name Str, f fun() !void) void {
    s.tests.push(Test(name, f))
}

pub fun Suite.run(s &mut Suite) SuiteResult {
    let @local = Arena()
    mut failed = 0
    for test_index in 0..s.tests.len {
        let test = s.tests.get(test_index)
        let prefix = f"{s.name}({test_index + 1}/{s.tests.len})\t{test.name}".build(@local)
        io.println(prefix)
        match test.f() {
            case Err e: 
                failed += 1
                io.print(prefix)
                io.println(" \x1b[31mFAILED\x1b[0m")
                if s.bail {
                    return SuiteResult(test_index - 1, failed)
                }
            else: 
        }
    }
    SuiteResult(s.tests.len - failed, failed)
}

pub enum AssertErr Err = 
    | mismatch
    | not_an_error
    | not_found

shape HasEqFmt {
    pub fun HasEqFmt.eq(e HasEqFmt, other HasEqFmt) Bool
    pub fun HasEqFmt.fmt(e HasEqFmt, sw &mut StrWriter) void
}

pub fun ok(b Bool, msg Str = "") !void { 
    if not b { 
        print_assert_err_msg(msg, "want: true, got: false")
        return AssertErr.mismatch
    }
}

pub fun not_ok(b Bool, msg Str = "") !void { 
    if b { 
        print_assert_err_msg(msg, "want: false, got: true")
        return AssertErr.mismatch
    }
}

pub fun contains_str(haystack Str, needle Str, msg Str = "") !void {
    if not haystack.contains(needle) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want '{haystack}' to contain {needle}'".build(@local))
        return AssertErr.not_found
    }
}

pub fun eq<T HasEqFmt>(want T, got T, msg Str = "") !void {
    if not want.eq(got) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {want}, got {got}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun neq<T HasEqFmt>(want T, got T, msg Str = "") !void {
    if want.eq(got) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {want} not to equal {got}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun gt_int(left Int, right Int, msg Str = "") !void {
    if not (left > right) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {left} > {right}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun gte_int(left Int, right Int, msg Str = "") !void {
    if not (left >= right) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {left} >= {right}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun lt_int(left Int, right Int, msg Str = "") !void {
    if not (left < right) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {left} < {right}".build(@local))
        return AssertErr.mismatch
    }
}

pub fun lte_int(left Int, right Int, msg Str = "") !void {
    if not (left <= right) {
        let @local = Arena()
        print_assert_err_msg(msg, f"want {left} <= {right}".build(@local))
        return AssertErr.mismatch
    }
}

