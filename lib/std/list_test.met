use std::test
use std::list

fun main() void {
    let @local = Arena()
    let suite = test::Suite.new("List", @local)
    suite.test("happy path", fun() !void {
        let @local = Arena()
        let sut = list::List.new<Int>(32, @local)
        sut.push(1)
        sut.push(2)
        sut.push(3)
        let slice = sut.as_slice()
        try test::eq(3, sut.len)
        try test::eq(3, slice.len)
        for i in 0..slice.len {
            try test::eq(i + 1, slice[i])
            try test::eq(i + 1, sut.get(i))
        }
        sut.set(1, 42)
        try test::eq(42, sut.get(1))
        try test::eq(42, slice[1])
    })
    suite.test("push_all", fun() !void {
        let @local = Arena()
        let sut = list::List.new<Int>(2, @local)
        sut.push_all([1, 2, 3][..])
        try test::eq([1, 2, 3][..], sut.as_slice())
    })
    suite.test("references get stale after push", fun() !void {
        let @local = Arena()
        let sut = list::List.new<Int>(32, @local)
        sut.push(1)
        let slice = sut.as_slice()
        let ref = &slice[0]
        try test::eq(1, sut.get(0))
        try test::eq(1, slice[0])
        try test::eq(1, ref.*)
        for i in 0..1000 {
            sut.push(i)
            try test::eq(i, sut.get(i + 1))
        }
        -- setting index 0 to a new value
        -- `ref` and `slice` should still point at the old data
        try test::eq(1, sut.get(0))
        try test::eq(1, slice[0])
        try test::eq(1, ref.*)
        sut.set(0, 42)
        try test::eq(42, sut.get(0))
        try test::eq(1, slice[0])
        try test::eq(1, ref.*)
    })
    suite.test("iter", fun() !void {
        let @local = Arena()
        let l = list::List.new<Int>(32, @local)
        l.push(1)
        l.push(2)
        l.push(3)
        mut iter = l.iter()
        let it = &mut iter
        try test::eq(Option(1), it.peek())
        try test::eq(Option(1), it.next())
        -- iterator reflects underlying data
        l.set(1, 42)
        try test::eq(Option(42), it.next())
        -- but push (when it re-allocates) makes underlying data stale
        for i in 0..256 { l.push(i) }
        l.set(2, 123)
        try test::eq(Option(3), it.next())
        -- and pushed elements are never reflected
        try test::eq(Option<Int>(None()), it.next(), "hh")
    })
    suite.test("sort_in_place", fun() !void {
        let @local = Arena()
        let sut = list::List.new<Int>(32, @local)
        sut.push(3)
        sut.push(2)
        sut.push(4)
        sut.push(1)
        sut.sort_in_place(fun (a Int, b Int) Int { if a == b { return 0 } if a < b { return 0 - 1 } return 1 })
        try test::eq(1, sut.get(0))
        try test::eq(2, sut.get(1))
        try test::eq(3, sut.get(2))
        try test::eq(4, sut.get(3))
    })
    suite.test("eq", fun() !void {
        let @local = Arena()
        let sut1 = list::List.new<Int>(32, @local)
        let sut2 = list::List.new<Int>(32, @local)

        try test::eq(sut1, sut2)

        sut1.push(1)
        sut2.push(1)
        try test::eq(sut1, sut2)

        sut1.push(2)
        try test::neq(sut1, sut2)

        sut2.push(2)
        try test::eq(sut1, sut2)

        sut1.push(3)
        sut2.push(4)
        try test::neq(sut1, sut2)
    })
    suite.test("fmt", fun() !void {
        let @local = Arena()
        let sut = list::List.new<Str>(32, @local)
        sut.push("hello")
        sut.push("there")
        sut.push("again")

        let sb = StrBuilder.new(32, @local)
        sb.fmt(sut)
        try test::eq("[hello, there, again]", sb.as_str())
    })
    _ = suite.run()
}
