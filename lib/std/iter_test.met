use std::test
use assert_ = std::assert
use std::iter
use std::list

fun main() void {
    let @local = Arena()
    let suite = test::suite("iter", @local)
    suite.test("count", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        try assert.eq(5, iter::count(&mut it))
    })
    suite.test("map", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut sut = iter::map(&mut it, fun(a Rune) U8 { a.to_u32().to_u8_wrapping() })
        try assert.eq(Option(U8(104)), (&mut sut).next())
        try assert.eq(Option(U8(101)), (&mut sut).next())
        try assert.eq(Option(U8(108)), (&mut sut).next())
        try assert.eq(Option(U8(108)), (&mut sut).next())
        try assert.eq(Option(U8(111)), (&mut sut).next())
        try assert.eq(Option<U8>(None()), (&mut sut).next())
    })
    suite.test("filter", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut sut = iter::filter(&mut it, fun(a Rune) Bool { a == 'l' })
        try assert.eq(Option('l'), (&mut sut).next())
        try assert.eq(Option('l'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
    })
    suite.test("all", fun(assert &assert_::Assert) !void {
        mut it = "aaaaa".iter()
        try assert.eq(true, iter::all(&mut it, fun(a Rune) Bool { a == 'a' }))
        it = "aaaab".iter()
        try assert.eq(false, iter::all(&mut it, fun(a Rune) Bool { a == 'a' }))
    })
    suite.test("any", fun(assert &assert_::Assert) !void {
        mut it = "aaaba".iter()
        try assert.eq(true, iter::any(&mut it, fun(a Rune) Bool { a == 'b' }))
        it = "aaaaa".iter()
        try assert.eq(false, iter::any(&mut it, fun(a Rune) Bool { a == 'b' }))
    })
    suite.test("chain", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        mut it1 = "aa".iter()
        let l = list::List.new<Rune>(@local)
        l.push('b')
        l.push('b')
        mut it2 = l.iter()
        mut sut = iter::chain(&mut it1, &mut it2)
        try assert.eq(Option('a'), (&mut sut).next())
        try assert.eq(Option('a'), (&mut sut).next())
        try assert.eq(Option('b'), (&mut sut).next())
        try assert.eq(Option('b'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
    })
    suite.test("fold", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let l = list::List.new<U8>(@local)
        l.push(1)
        l.push(2)
        l.push(3)
        mut it = l.iter()
        try assert.eq(16, iter::fold(&mut it, 10, fun(sum Int, v U8) Int { sum + v.to_int() }))
    })
    suite.test("peekable", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut sut = iter::peekable(&mut it)
        try assert.eq(Option('h'), (&mut sut).peek())
        try assert.eq(Option('h'), (&mut sut).peek())
        try assert.eq(Option('h'), (&mut sut).next())
        try assert.eq(Option('e'), (&mut sut).peek())
        try assert.eq(Option('e'), (&mut sut).next())
        try assert.eq(Option('l'), (&mut sut).next())
        try assert.eq(Option('l'), (&mut sut).next())
        try assert.eq(Option('o'), (&mut sut).peek())
        try assert.eq(Option('o'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).peek())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
    })
    suite.test("take", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut sut = iter::take(&mut it, 2)
        try assert.eq(Option('h'), (&mut sut).next())
        try assert.eq(Option('e'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
        try assert.eq(Option('l'), (&mut it).next())

        it = "hi".iter()
        sut = iter::take(&mut it, 10)
        try assert.eq(Option('h'), (&mut sut).next())
        try assert.eq(Option('i'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
    })
    suite.test("take_while", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut peekable_it = iter::peekable(&mut it)
        mut sut = iter::take_while(&mut peekable_it, fun(r Rune) Bool { r != 'l'})
        try assert.eq(Option('h'), (&mut sut).next())
        try assert.eq(Option('e'), (&mut sut).next())
        try assert.eq(Option<Rune>(None()), (&mut sut).next())
        try assert.eq(Option('l'), (&mut it).next())

        -- list.iter() is already peekable
        let @local = Arena()
        mut l = list::List.new<Int>(@local)
        l.push(1)
        l.push(2)
        l.push(3)
        mut list_iter = l.iter()
        mut list_sut = iter::take_while(&mut list_iter, fun(i Int) Bool { i < 3 })
        try assert.eq(Option(1), (&mut list_sut).next())
        try assert.eq(Option(2), (&mut list_sut).next())
        try assert.eq(Option<Int>(None()), (&mut list_sut).next())
        try assert.eq(Option(3), (&mut list_iter).next())
    })
    suite.test("collect", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        mut it = "hello".iter()
        mut l = list::List.new<Rune>(@local)
        iter::collect(&mut it, l)
        try assert.eq(5, l.len)
    })
    suite.test("find", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        try assert.eq(Option('e'), iter::find(&mut it, fun(a Rune) Bool { a == 'e' }))
        try assert.eq(Option<Rune>(None()), iter::find(&mut it, fun(a Rune) Bool { a == '!' }))
    })
    suite.test("combine multiple", fun(assert &assert_::Assert) !void {
        mut it = "hello".iter()
        mut map = iter::map(&mut it, fun(a Rune) U8 { a.to_u32().to_u8_wrapping() })
        mut filter = iter::filter(&mut map, fun(a U8) Bool { a == 108 })
        try assert.eq(2, iter::count(&mut filter))
    })
    _ = suite.run()
}
