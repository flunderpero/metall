use std.map

pub struct Set<T map.Key> {
    m &mut map.Map<T, Bool>
}

pub fun Set.new(capacity Int, @a Arena) &mut Set {
    let m = map.Map.new<T, Bool>(capacity, @a)
    @a.new(Set<T>(m))
}

pub fun Set.len(s &Set) Int {
    s.m.len
}

pub fun Set.add(s &mut Set, value T) void {
    s.m.set(value, true)
}

pub fun Set.del(s &mut Set, value T) Bool {
    s.m.del(value)
}

pub fun Set.has(s &Set, value T) Bool {
    s.m.has(value)
}
