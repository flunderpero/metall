fun print<T HasFmt>(s T) void {
    -- todo: We should be able to have a shortcut if is is Str.
    let @a = Arena()
    let sb = StrBuilder.new(32, @a)
    s.fmt(sb)
    LibCIntern.write(1, sb.to_str().utf8_bytes())
}

fun println<T HasFmt>(s T) void {
    print<T>(s)
    LibCIntern.write(1, [U8(10)][..])
}
