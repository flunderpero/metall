use std::test
use std::os

fun main() void {
    let @local = Arena()
    let suite = test::Suite.new("shell", @local)
    suite.test("happy path", fun() !void {
        let @local = Arena()
        let res = try os::shell(["printf", "hello"][..], @local) 
        try test::eq(0, res.status)
        try test::eq("hello", res.output)
    })
    suite.test("not existing program", fun() !void {
        let @local = Arena()
        let res = try os::shell(["this_does_not_exist"][..], @local)
        try test::neq(0, res.status)
        try test::contains_str(res.output, "not found")
    })
    _ = suite.run()
}
