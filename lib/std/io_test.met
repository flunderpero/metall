use std::test
use std::io

fun main() !void {
    let @local = Arena()
    let buffer_suite = test::Suite.new("Buffer", @local)
    buffer_suite.test("happy path", fun() !void {
        let @local = Arena()
        let sut = io::Buffer.new<Int>(32, @local)
        try test::eq(Result(3), sut.write([1, 2, 3][..]))
        try test::eq(Result(4), sut.write([4, 5, 6, 7][..]))

        let read_buf = @local.slice_mut(10, 0)
        try test::eq([1, 2][..], try sut.read(read_buf[0..=1]))
        try test::eq([3, 4, 5][..], try sut.read(read_buf[0..=2]))
        try test::eq([6, 7][..], try sut.read(read_buf))
    })
    buffer_suite.test("close", fun() !void {
        let @local = Arena()
        let sut = io::Buffer.new<Int>(32, @local)
        _ = try sut.write([1, 2, 3, 4][..])

        let read_buf = @local.slice_mut(10, 0)
        try test::eq([1, 2][..], try sut.read(read_buf[0..=1]))

        try sut.close()
        let read_bytes = try sut.read(read_buf)
        try test::eq(0, read_bytes.len)
    })
    _ = buffer_suite.run()

    let read_all_suite = test::Suite.new("read_all", @local)
    read_all_suite.test("happy path", fun() !void {
        let @local = Arena()
        let sut = io::Buffer.new<Int>(32, @local)
        for i in 0..10000 {
            _ = try sut.write([i, i * 2, i * 3, i * 4, i * 5][..])
        }
        let read = try io::read_all(sut, -1, @local)
        try test::eq(10000 * 5, read.len)
    })
    read_all_suite.test("capped", fun() !void {
        let @local = Arena()
        let sut = io::Buffer.new<Int>(32, @local)
        _ = try sut.write([1, 2, 3, 4, 5][..])
        let read = try io::read_all(sut, 1, @local)
        try test::eq([1][..], read)
    })
    _ = read_all_suite.run()
}
