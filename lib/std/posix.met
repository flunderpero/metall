use std.ffi

#if os.darwin
extern("__error") fun __errno() ffi.PtrMut<I32>
#end
#if os.linux
extern("__errno_location") fun __errno() ffi.PtrMut<I32>
#end

#if not os.wasm
extern("strerror") fun strerror_(e I32) ffi.Ptr<U8>
extern fun strlen(s ffi.Ptr<U8>) Int
#end

--- Posix `errno` representation. 

    Why not just use the enum `ErrnoKind`? Because the list of errno
    constants might change.
---
pub struct Errno {
    pub value I32
}

pub fun Errno.from_kind(e ErrnoKind) Errno {
    Errno(e.tag)
}

pub fun Errno.eq(e Errno, o Errno) Bool { e.value == o.value }

pub fun Errno.hash(e Errno) U64 { e.value.hash() }

pub fun Errno.fmt(e Errno, sb &mut StrBuilder) void {
    sb.str(e.to_str())
}

pub fun Errno.to_str(e Errno) Str {
    #if os.wasm
    "Errno.to_str() not supported on wasm"
    #end
    #if not os.wasm
    -- todo: Make the first character lower case.
    let cstr = unsafe strerror_(e.value)
    let l = unsafe strlen(cstr)
    try Str.from_utf8_checked(unsafe cstr.as_slice(l)) else e { panic(e.debug_name) }
    #end
}

