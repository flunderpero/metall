pub fun reset_errno() void {
    #if not os.wasm
    let e = unsafe __errno()
    unsafe e.write(0)
    #end
}

--- Return the posix `errno` value or panic if it is not set (0). ---
pub fun errno() Errno {
    #if os.wasm
    Errno(0)
    #end
    #if not os.wasm
    let raw = unsafe (unsafe __errno()).read()
    Errno(raw)
    #end
}
