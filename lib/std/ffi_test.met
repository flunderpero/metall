use std.test
use std.ffi
#if not os.wasm
use std.fs
#end

fun main() void {
    let @local = Arena()

    let fun_ptr_suite = test.Suite.new("fun_ptr", @local)
    #if not os.wasm
    fun_ptr_suite.test("fun", fun() !void {
        let @local = Arena()
        fun hello() void {
            -- todo: Use a proper temporary file.
            _ = fs.write_file(fs.Path.from_str("/tmp/ffi_test.met.file"), "hello".as_bytes())
        }
        let f = ffi.fun_ptr(hello)
        f.call()
        let read = try fs.read_file(fs.Path.from_str("/tmp/ffi_test.met.file"), @local)
        try test.eq("hello".as_bytes(), read) 
    })
    #end
    fun_ptr_suite.test("closure", fun() !void {
        mut value = ""
        let hello = fun[&mut value]() void {
            value.* = "hello"
        }
        let f = ffi.fun_ptr(hello)
        f.call()
        try test.eq("hello", value)
    })
    _ = fun_ptr_suite.run()

    let memcopy_suite = test.Suite.new("memcopy", @local)
    memcopy_suite.test("happy path", fun() !void {
        struct Point<T> {
            x T
            y T
        }
        let a = Point(1, 2)
        mut b = Point(99, 99)
        unsafe ffi.memcopy(ffi.ref_ptr_mut<Point<Int>>(&mut b), ffi.ref_ptr<Point<Int>>(&a), 1)
        try test.eq(1, a.x)
        try test.eq(2, a.y)
    })
    memcopy_suite.test("slice", fun() !void {
        let a = [1, 2, 3, 4, 5][..]
        mut b = [0, 0, 0, 0, 0][..]
        unsafe ffi.memcopy(ffi.slice_ptr_mut<Int>(b), ffi.slice_ptr<Int>(a), 2)
        try test.eq([1, 2, 0, 0, 0][..], b)
        unsafe ffi.memcopy(ffi.slice_ptr_mut<Int>(b), ffi.slice_ptr<Int>(a), 5)
        try test.eq([1, 2, 3, 4, 5][..], b)
    })
    _ = memcopy_suite.run()

    let cast_suite = test.Suite.new("cast", @local)
    cast_suite.test("PtrMut.cast", fun() !void {
        struct Point {
            x Int
            y Int
        }
        mut p = Point(1, 2)
        let ptr = ffi.ref_ptr_mut<Point>(&mut p)
        let r = unsafe ptr.cast()
        r.x = 10
        r.y = 20
        try test.eq(10, p.x)
        try test.eq(20, p.y)
    })
    cast_suite.test("Ptr.cast", fun() !void {
        struct Point {
            x Int
            y Int
        }
        let p = Point(3, 4)
        let ptr = ffi.ref_ptr(&p)
        let r = unsafe ptr.cast()
        try test.eq(3, r.x)
        try test.eq(4, r.y)
    })
    _ = cast_suite.run()

    let rw_suite = test.Suite.new("read/write", @local)
    rw_suite.test("Ptr.read_at", fun() !void {
        struct Foo {
            a Bool
            b U32
            c U32
            d [3]U8
        }
        let f = Foo(false, 1, 2, [U8('b'), 'a', 'r'])
        let ptr = ffi.ref_ptr(&f)
        -- Foo.a is 1 byte
        -- Foo.b is aligned at 4
        -- Foo.c is aligned at 8
        try test.eq(U32(2), unsafe ptr.read_at<U32>(8))
        try test.eq(U32(1), unsafe ptr.read_at<U32>(4))
        let u8_arr = unsafe ptr.read_at<[3]U8>(12)
        try test.eq(U8('b'), u8_arr[0])
        try test.eq(U8('a'), u8_arr[1])
        try test.eq(U8('r'), u8_arr[2])
    })
    rw_suite.test("PtrMut.read_at + write_at", fun() !void {
        struct Foo {
            a Bool
            b U32
            c U32
            d [3]U8
        }
        mut f = Foo(false, 1, 2, [U8('b'), 'a', 'r'])
        let ptr = ffi.ref_ptr_mut(&mut f)
        -- Foo.a is 1 byte
        -- Foo.b is aligned at 4
        -- Foo.c is aligned at 8
        try test.eq(U32(2), unsafe ptr.read_at<U32>(8))
        try test.eq(U32(1), unsafe ptr.read_at<U32>(4))
        let u8_arr = unsafe ptr.read_at<[3]U8>(12)
        try test.eq(U8('b'), u8_arr[0])
        try test.eq(U8('a'), u8_arr[1])
        try test.eq(U8('r'), u8_arr[2])

        unsafe ptr.write_at<U32>(8, 42)
        try test.eq(U32(42), unsafe ptr.read_at<U32>(8))
        try test.eq(U32(42), f.c)
    })
    _ = rw_suite.run()
}
