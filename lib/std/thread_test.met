use std.test
use std.thread
use std.time
use std.iter
use std.io
use std.os
use std.fs

let test_filename = "/tmp/thread_test.met.file"

fun main() void {
    let @local = Arena()

    let thread_suite = test.Suite.new("spawn", @local)
    thread_suite.test("happy path", fun() !void {
        let @local = Arena()
        let captured = "hello"
        let sut = try thread.spawn(@local, fun[captured]() {
            captured
        })
        try test.eq("hello", try sut.join())
    })
    thread_suite.test("spawn with void fun", fun() !void {
        let @local = Arena()
        -- todo: Use fs.rm(path) once it is there
        try os.shell_checked(["rm", "-f", test_filename][..], @local)

        let sut = try thread.spawn(@local, fun() {
            try fs.write_file(fs.Path.from_str(test_filename), "hello".as_bytes()) else { return void }
        })
        try sut.join()
        try test.eq("hello".as_bytes(), try fs.read_file(fs.Path.from_str(test_filename), @local))
    })
    _ = thread_suite.run()


    let tg_suite = test.Suite.new("ThreadGroup", @local)
    tg_suite.test("happy path", fun() !void {
        let @local = Arena()
        let sut = thread.ThreadGroup.new<Int>(@local)
        try sut.spawn(fun() { 1337 })
        try sut.spawn(fun() { 42 })
        try sut.spawn(fun() { 137 })
        mut res = iter.pipe(sut.join(@local).iter())
            .map(fun(a) Int { try a else { return -1 } })
            .collect(16, @local)
        res.sort_in_place(Int.cmp)
        try test.eq([42, 137, 1337][..], res)
    })
    _ = tg_suite.run()

    let mutex_suite = test.Suite.new("Mutex", @local)
    mutex_suite.test("with_lock", fun() !void {
        let @local = Arena()
        let sut = thread.Mutex.new<Int>(0, @local)
        let tg = thread.ThreadGroup.new<!void>(@local)
        let thread_fun = fun[sut]() !void {
            for i in 0..100 {
                try sut.with_lock(fun(v) {
                    v.* += 1
                })
                time.sleep(time.microsecond)
            }
        }
        for i in 0..10 {
            try tg.spawn(thread_fun)
        }
        _ = tg.join(@local)
        try test.eq(1000, try sut.lock_and_copy_value())
    })
    mutex_suite.test("with_try_lock", fun() !void {
        let @local = Arena()
        let sut = thread.Mutex.new<Int>(0, @local)
        -- While this thread holds the lock, a try_lock on another thread must
        -- miss, leaving the value untouched.
        try try sut.with_lock(fun[sut, @local](v) !void {
            let t = try thread.spawn(@local, fun[sut]() !void {
                _ = try sut.with_try_lock(fun(c) {
                    c.* += 1
                })
            })
            try t.join()
        })
        try test.eq(0, try sut.lock_and_copy_value())
        -- Now it should succeed.
        _= try sut.with_try_lock(fun(v) { v.* = 99 })
        try test.eq(99, try sut.lock_and_copy_value())
        
    })
    mutex_suite.test("with_try_lock stress", fun() !void {
        let @local = Arena()
        let sut = thread.Mutex.new<Int>(0, @local)
        let tg = thread.ThreadGroup.new<!void>(@local)
        let thread_fun = fun[sut]() !void {
            for i in 0..100 {
                _ = try sut.with_try_lock(fun(v) {
                    v.* += 1
                })
                time.sleep(time.microsecond)
            }
        }
        for i in 0..10 {
            try tg.spawn(thread_fun)
        }
        _ = tg.join(@local)
        try test.lte_int(try sut.lock_and_copy_value(), 1000)
    })
    _ = mutex_suite.run()
}
