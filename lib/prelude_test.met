use std::test
use assert_ = std::assert

fun main() void {
    let @local = Arena()

    let str_suite = test::suite("Str", @local)
    str_suite.test("concat", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        try assert.eq("hello there", "hello ".concat("there", @local))
    })
    str_suite.test("contains", fun(assert &assert_::Assert) !void {
        try assert.ok("test".contains("test"))
        try assert.not_ok("test".contains("a"))
        try assert.not_ok("test".contains("test1"))
        try assert.ok("test".contains(""))
        try assert.not_ok("".contains("test"))
        try assert.ok("".contains(""))
    })
    str_suite.test("decapitalize", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        try assert.eq("hELLO", "HELLO".decapitalize(@local))
    })
    str_suite.test("hash", fun(assert &assert_::Assert) !void {
        try assert.eq(U64(686710930086579414), "hello".hash())
        try assert.eq(U64(0), "".hash())
    })
    str_suite.test("iter", fun(assert &assert_::Assert) !void {
        let s = "hi!"
        mut iter = s.iter()
        let it = &mut iter
        try assert.eq(Option('h'), it.next())
        try assert.eq(Option('i'), it.next())
        try assert.eq(Option('!'), it.next())
        try assert.eq(Option<Rune>(None()), it.next())
    })
    str_suite.run()

    let rune_suite = test::suite("Rune", @local)
    rune_suite.test("from_u32_lossy", fun(assert &assert_::Assert) !void {
        try assert.eq('A', Rune.from_u32_lossy(65))
        try assert.eq('�', Rune.from_u32_lossy(123456789))
        try assert.eq('�', Rune.from_u32_lossy(55296)) -- 0xD800
    })
    rune_suite.run()

    let str_builder_suite = test::suite("StrBuilder", @local)
    str_builder_suite.test("u64", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let sut = StrBuilder.new(32, @local)
        sut.u64(13370).str(" ")
        sut.u64(13370, 2).str(" ")
        sut.u64(13370, 8).str(" ")
        sut.u64(13370, 10).str(" ")
        sut.u64(13370, 16).str(" ")
        sut.u64(13370, 16, true)
        try assert.eq("13370 11010000111010 32072 13370 343a 343A", sut.to_str())
    })
    str_builder_suite.test("int", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let sut = StrBuilder.new(32, @local)
        sut.int(13370).str(" ")
        sut.int(0 - 13370).str(" ")
        sut.int(13370, 2).str(" ")
        sut.int(13370, 8).str(" ")
        sut.int(13370, 10).str(" ")
        sut.int(13370, 16).str(" ")
        sut.int(13370, 16, true)
        try assert.eq("13370 -13370 11010000111010 32072 13370 343a 343A", sut.to_str())
    })
    str_builder_suite.run()
}
