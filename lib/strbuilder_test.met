use std::test
use std::list
use assert_ = std::assert

fun main() void {
    let @local = Arena()

    let suite = test::suite("StrBuilder", @local)
    suite.test("u64", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let sut = StrBuilder.new(32, @local)
        _ = sut.u64(13370).str(" ")
        _ = sut.u64(13370, 2).str(" ")
        _ = sut.u64(13370, 8).str(" ")
        _ = sut.u64(13370, 10).str(" ")
        _ = sut.u64(13370, 16).str(" ")
        _ = sut.u64(13370, 16, true)
        try assert.eq("13370 11010000111010 32072 13370 343a 343A", sut.to_str())
    })
    suite.test("int", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let sut = StrBuilder.new(32, @local)
        _ = sut.int(13370).str(" ")
        _ = sut.int(0 - 13370).str(" ")
        _ = sut.int(13370, 2).str(" ")
        _ = sut.int(13370, 8).str(" ")
        _ = sut.int(13370, 10).str(" ")
        _ = sut.int(13370, 16).str(" ")
        _ = sut.int(13370, 16, true)
        try assert.eq("13370 -13370 11010000111010 32072 13370 343a 343A", sut.to_str())
    })
    suite.test("join", fun(assert &assert_::Assert) !void {
        let @local = Arena()
        let sut = StrBuilder.new(32, @local)
        let l = list::List.new<Int>(0, @local)
        l.push(1)
        l.push(2)
        l.push(3)
        mut it = l.iter()
        _ = sut.join(&mut it, ", ")
        try assert.eq("1, 2, 3", sut.to_str())
    })
    _ = suite.run()
}
