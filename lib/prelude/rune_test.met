use std::test

fun main() void {
    let @local = Arena()

    let suite = test::Suite.new("Rune", @local)
    suite.test("from_u32_lossy", fun() !void {
        try test::eq('A', Rune.from_u32_lossy(65))
        try test::eq('\u{FFFD}', Rune.from_u32_lossy(123456789))
        try test::eq('\u{FFFD}', Rune.from_u32_lossy(55296)) -- 0xD800
    })
    suite.test("from_u32_checked", fun() !void {
        try test::eq(Result('A'), Rune.from_u32_checked(65))
        try test::err(Rune.from_u32_checked(123456789), "rune out of range")
        try test::err(Rune.from_u32_checked(55296), "rune in invalid surrogate range") -- 0xD800
    })
    suite.test("to_bytes", fun() !void {
        let @local = Arena()
        {
            let rune = 'A'.to_bytes()
            try test::eq("A", Str.from_utf8_lossy((&rune).as_slice(), @local))
        }
        {
            let rune = 'ä'.to_bytes()
            try test::eq("ä", Str.from_utf8_lossy((&rune).as_slice(), @local))
        }
        {
            let rune = '€'.to_bytes()
            try test::eq("€", Str.from_utf8_lossy((&rune).as_slice(), @local))
        }
        {
            let rune = '😀'.to_bytes()
            try test::eq("😀", Str.from_utf8_lossy((&rune).as_slice(), @local))
        }
    })
    suite.test("is_ascii_whitespace", fun() !void {
        try test::eq(true, ' '.is_ascii_whitespace())
        try test::eq(true, '\n'.is_ascii_whitespace())
        try test::eq(true, '\t'.is_ascii_whitespace())
        try test::eq(true, '\r'.is_ascii_whitespace())
        try test::eq(true, '\x0C'.is_ascii_whitespace())
        try test::eq(false, 'a'.is_ascii_whitespace())
    })
    suite.test("is_ascii_lower", fun() !void {
        try test::eq(true, 'a'.is_ascii_lower())
        try test::eq(true, 'z'.is_ascii_lower())
        try test::eq(false, 'A'.is_ascii_lower())
        try test::eq(false, 'Z'.is_ascii_lower())
        try test::eq(false, ' '.is_ascii_lower())
    })
    suite.test("is_ascii_upper", fun() !void {
        try test::eq(true, 'A'.is_ascii_upper())
        try test::eq(true, 'Z'.is_ascii_upper())
        try test::eq(false, 'a'.is_ascii_upper())
        try test::eq(false, 'z'.is_ascii_upper())
        try test::eq(false, ' '.is_ascii_upper())
    })
    suite.test("is_ascii_digit", fun() !void {
        try test::eq(true, '0'.is_ascii_digit())
        try test::eq(true, '5'.is_ascii_digit())
        try test::eq(true, '9'.is_ascii_digit())
        try test::eq(false, 'A'.is_ascii_digit())
        try test::eq(false, 'Z'.is_ascii_digit())
        try test::eq(false, 'a'.is_ascii_digit())
        try test::eq(false, 'z'.is_ascii_digit())
        try test::eq(false, ' '.is_ascii_digit())
    })
    suite.test("is_ascii_alpha", fun() !void {
        try test::eq(false, ' '.is_ascii_alpha())
        try test::eq(false, '0'.is_ascii_alpha())
        try test::eq(false, '9'.is_ascii_alpha())
        try test::eq(true, 'A'.is_ascii_alpha())
        try test::eq(true, 'Z'.is_ascii_alpha())
        try test::eq(true, 'a'.is_ascii_alpha())
        try test::eq(true, 'z'.is_ascii_alpha())
    })
    suite.test("is_ascii_alphanumeric", fun() !void {
        try test::eq(false, ' '.is_ascii_alphanumeric())
        try test::eq(true, '0'.is_ascii_alphanumeric())
        try test::eq(true, '9'.is_ascii_alphanumeric())
        try test::eq(true, 'A'.is_ascii_alphanumeric())
        try test::eq(true, 'Z'.is_ascii_alphanumeric())
        try test::eq(true, 'a'.is_ascii_alphanumeric())
        try test::eq(true, 'z'.is_ascii_alphanumeric())
    })
    suite.test("is_whitespace", fun() !void {
        try test::eq(true, ' '.is_whitespace())
        try test::eq(true, '\n'.is_whitespace())
        try test::eq(true, '\t'.is_whitespace())
        try test::eq(true, '\r'.is_whitespace())
        try test::eq(true, '\x0C'.is_whitespace())
        try test::eq(false, 'a'.is_whitespace())
    })
    suite.test("is_lower", fun() !void {
        try test::eq(true, 'a'.is_lower())
        try test::eq(true, 'z'.is_lower())
        try test::eq(false, 'A'.is_lower())
        try test::eq(false, 'Z'.is_lower())
        try test::eq(false, ' '.is_lower())
    })
    suite.test("is_upper", fun() !void {
        try test::eq(true, 'A'.is_upper())
        try test::eq(true, 'Z'.is_upper())
        try test::eq(false, 'a'.is_upper())
        try test::eq(false, 'z'.is_upper())
        try test::eq(false, ' '.is_upper())
    })
    suite.test("is_digit", fun() !void {
        try test::eq(true, '0'.is_digit())
        try test::eq(true, '5'.is_digit())
        try test::eq(true, '9'.is_digit())
        try test::eq(false, 'A'.is_digit())
        try test::eq(false, 'Z'.is_digit())
        try test::eq(false, 'a'.is_digit())
        try test::eq(false, 'z'.is_digit())
        try test::eq(false, ' '.is_digit())
    })
    suite.test("is_alpha", fun() !void {
        try test::eq(false, ' '.is_alpha())
        try test::eq(false, '0'.is_alpha())
        try test::eq(false, '9'.is_alpha())
        try test::eq(true, 'A'.is_alpha())
        try test::eq(true, 'Z'.is_alpha())
        try test::eq(true, 'a'.is_alpha())
        try test::eq(true, 'z'.is_alpha())
    })
    suite.test("is_alphanumeric", fun() !void {
        try test::eq(false, ' '.is_alphanumeric())
        try test::eq(true, '0'.is_alphanumeric())
        try test::eq(true, '9'.is_alphanumeric())
        try test::eq(true, 'A'.is_alphanumeric())
        try test::eq(true, 'Z'.is_alphanumeric())
        try test::eq(true, 'a'.is_alphanumeric())
        try test::eq(true, 'z'.is_alphanumeric())
    })
    _ = suite.run()
}
