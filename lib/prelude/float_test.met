        ParseCase("9007199254740995", 4845873199050653698),       -- tie above 2^53, rounds to even
        ParseCase("4503599627370497.5", 4841369599423283202),     -- fractional .5 tie at 2^52
        ParseCase("18014398509481990", 4850376798678024194),      -- tie near 2^54 (ulp 4)
        ParseCase("1.7976931348623158e308", 9218868437227405311), -- rounds down to MaxFloat64
