        ParseCase("00.5", 4602678819172646912),
        ParseCase("5.e3", 4662219572839972864),
        ParseCase("+.5e+2", 4632233691727265792),
        ParseCase("-0.0", U64(9223372036854775808)),   -- the parser produces -0.0
