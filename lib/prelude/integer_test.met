use std.test

fun main() void {
    let @local = Arena()
    let checked_suite = test.Suite.new("to_x_checked", @local)
    checked_suite.test("U8.to_i8_checked", fun() !void {
        try test.eq(Result(I8(0)), U8(0).to_i8_checked())
        try test.eq(Result(I8(0x7F)), U8(0x7F).to_i8_checked())
        try test.err(U8(0x80).to_i8_checked(), "number out of range")
    })
    checked_suite.test("U16.to_i16_checked", fun() !void {
        try test.eq(Result(I16(0)), U16(0).to_i16_checked())
        try test.eq(Result(I16(0x7FFF)), U16(0x7FFF).to_i16_checked())
        try test.err(U16(0x8000).to_i16_checked(), "number out of range")
    })
    checked_suite.test("U32.to_i32_checked", fun() !void {
        try test.eq(Result(I32(0)), U32(0).to_i32_checked())
        try test.eq(Result(I32(0x7FFF_FFFF)), U32(0x7FFF_FFFF).to_i32_checked())
        try test.err(U32(0x8000_0000).to_i32_checked(), "number out of range")
    })
    checked_suite.test("U64.to_int_checked", fun() !void {
        try test.eq(Result(Int(0)), U64(0).to_int_checked())
        try test.eq(Result(Int(0x7FFF_FFFF_FFFF_FFFF)), U64(0x7FFF_FFFF_FFFF_FFFF).to_int_checked())
        try test.err(U64(0x8000_0000_0000_0000).to_int_checked(), "number out of range")
    })
    checked_suite.test("I8.to_u8_checked", fun() !void {
        try test.eq(Result(U8(0)), I8(0).to_u8_checked())
        try test.eq(Result(U8(0x7F)), I8(0x7F).to_u8_checked())
        try test.err(I8(-1).to_u8_checked(), "number out of range")
    })
    checked_suite.test("I16.to_u16_checked", fun() !void {
        try test.eq(Result(U16(0)), I16(0).to_u16_checked())
        try test.eq(Result(U16(0x7FFF)), I16(0x7FFF).to_u16_checked())
        try test.err(I16(-1).to_u16_checked(), "number out of range")
    })
    checked_suite.test("I32.to_u32_checked", fun() !void {
        try test.eq(Result(U32(0)), I32(0).to_u32_checked())
        try test.eq(Result(U32(0x7FFF_FFFF)), I32(0x7FFF_FFFF).to_u32_checked())
        try test.err(I32(-1).to_u32_checked(), "number out of range")
    })
    checked_suite.test("Int.to_u64_checked", fun() !void {
        try test.eq(Result(U64(0)), Int(0).to_u64_checked())
        try test.eq(Result(U64(0x7FFF_FFFF_FFFF_FFFF)), Int(0x7FFF_FFFF_FFFF_FFFF).to_u64_checked())
        try test.err(Int(-1).to_u64_checked(), "number out of range")
    })
    checked_suite.test("U64.to_u32_checked", fun() !void {
        try test.eq(Result(U32(0)), U64(0).to_u32_checked())
        try test.eq(Result(U32(0xFFFF_FFFF)), U64(0xFFFF_FFFF).to_u32_checked())
        try test.err(U64(0x1_0000_0000).to_u32_checked(), "number out of range")
    })
    checked_suite.test("U64.to_u16_checked", fun() !void {
        try test.eq(Result(U16(0)), U64(0).to_u16_checked())
        try test.eq(Result(U16(0xFFFF)), U64(0xFFFF).to_u16_checked())
        try test.err(U64(0x1_0000).to_u16_checked(), "number out of range")
    })
    checked_suite.test("U64.to_u8_checked", fun() !void {
        try test.eq(Result(U8(0)), U64(0).to_u8_checked())
        try test.eq(Result(U8(0xFF)), U64(0xFF).to_u8_checked())
        try test.err(U64(0x100).to_u8_checked(), "number out of range")
    })
    checked_suite.test("U32.to_u16_checked", fun() !void {
        try test.eq(Result(U16(0)), U32(0).to_u16_checked())
        try test.eq(Result(U16(0xFFFF)), U32(0xFFFF).to_u16_checked())
        try test.err(U32(0x1_0000).to_u16_checked(), "number out of range")
    })
    checked_suite.test("U32.to_u8_checked", fun() !void {
        try test.eq(Result(U8(0)), U32(0).to_u8_checked())
        try test.eq(Result(U8(0xFF)), U32(0xFF).to_u8_checked())
        try test.err(U32(0x100).to_u8_checked(), "number out of range")
    })
    checked_suite.test("U16.to_u8_checked", fun() !void {
        try test.eq(Result(U8(0)), U16(0).to_u8_checked())
        try test.eq(Result(U8(0xFF)), U16(0xFF).to_u8_checked())
        try test.err(U16(0x100).to_u8_checked(), "number out of range")
    })
    checked_suite.test("Int.to_i32_checked", fun() !void {
        try test.eq(Result(I32(-0x8000_0000)), Int(-0x8000_0000).to_i32_checked())
        try test.eq(Result(I32(0x7FFF_FFFF)), Int(0x7FFF_FFFF).to_i32_checked())
        try test.err(Int(0x8000_0000).to_i32_checked(), "number out of range")
        try test.err(Int(-0x8000_0001).to_i32_checked(), "number out of range")
    })
    checked_suite.test("Int.to_i16_checked", fun() !void {
        try test.eq(Result(I16(-0x8000)), Int(-0x8000).to_i16_checked())
        try test.eq(Result(I16(0x7FFF)), Int(0x7FFF).to_i16_checked())
        try test.err(Int(0x8000).to_i16_checked(), "number out of range")
        try test.err(Int(-0x8001).to_i16_checked(), "number out of range")
    })
    checked_suite.test("Int.to_i8_checked", fun() !void {
        try test.eq(Result(I8(-0x80)), Int(-0x80).to_i8_checked())
        try test.eq(Result(I8(0x7F)), Int(0x7F).to_i8_checked())
        try test.err(Int(0x80).to_i8_checked(), "number out of range")
        try test.err(Int(-0x81).to_i8_checked(), "number out of range")
    })
    checked_suite.test("I32.to_i16_checked", fun() !void {
        try test.eq(Result(I16(-0x8000)), I32(-0x8000).to_i16_checked())
        try test.eq(Result(I16(0x7FFF)), I32(0x7FFF).to_i16_checked())
        try test.err(I32(0x8000).to_i16_checked(), "number out of range")
        try test.err(I32(-0x8001).to_i16_checked(), "number out of range")
    })
    checked_suite.test("I32.to_i8_checked", fun() !void {
        try test.eq(Result(I8(-0x80)), I32(-0x80).to_i8_checked())
        try test.eq(Result(I8(0x7F)), I32(0x7F).to_i8_checked())
        try test.err(I32(0x80).to_i8_checked(), "number out of range")
        try test.err(I32(-0x81).to_i8_checked(), "number out of range")
    })
    checked_suite.test("I16.to_i8_checked", fun() !void {
        try test.eq(Result(I8(-0x80)), I16(-0x80).to_i8_checked())
        try test.eq(Result(I8(0x7F)), I16(0x7F).to_i8_checked())
        try test.err(I16(0x80).to_i8_checked(), "number out of range")
        try test.err(I16(-0x81).to_i8_checked(), "number out of range")
    })
    _ = checked_suite.run()

    let clamped_suite = test.Suite.new("to_x_clamped", @local)
    --- Signed narrowing clamped ---
    clamped_suite.test("I16.to_i8_clamped", fun() !void {
        try test.eq(I8(0), I16(0).to_i8_clamped())
        try test.eq(I8(0x7F), I16(0x7F).to_i8_clamped())
        try test.eq(I8(-0x80), I16(-0x80).to_i8_clamped())
        try test.eq(I8(0x7F), I16(0x80).to_i8_clamped())
        try test.eq(I8(-0x80), I16(-0x81).to_i8_clamped())
        try test.eq(I8(0x7F), I16(0x7FFF).to_i8_clamped())
        try test.eq(I8(-0x80), I16(-0x8000).to_i8_clamped())
    })
    clamped_suite.test("I32.to_i8_clamped", fun() !void {
        try test.eq(I8(0), I32(0).to_i8_clamped())
        try test.eq(I8(0x7F), I32(0x7F).to_i8_clamped())
        try test.eq(I8(-0x80), I32(-0x80).to_i8_clamped())
        try test.eq(I8(0x7F), I32(0x80).to_i8_clamped())
        try test.eq(I8(-0x80), I32(-0x81).to_i8_clamped())
    })
    clamped_suite.test("Int.to_i8_clamped", fun() !void {
        try test.eq(I8(0), Int(0).to_i8_clamped())
        try test.eq(I8(0x7F), Int(0x7F).to_i8_clamped())
        try test.eq(I8(-0x80), Int(-0x80).to_i8_clamped())
        try test.eq(I8(0x7F), Int(0x80).to_i8_clamped())
        try test.eq(I8(-0x80), Int(-0x81).to_i8_clamped())
    })
    clamped_suite.test("I32.to_i16_clamped", fun() !void {
        try test.eq(I16(0), I32(0).to_i16_clamped())
        try test.eq(I16(0x7FFF), I32(0x7FFF).to_i16_clamped())
        try test.eq(I16(-0x8000), I32(-0x8000).to_i16_clamped())
        try test.eq(I16(0x7FFF), I32(0x8000).to_i16_clamped())
        try test.eq(I16(-0x8000), I32(-0x8001).to_i16_clamped())
    })
    clamped_suite.test("Int.to_i16_clamped", fun() !void {
        try test.eq(I16(0), Int(0).to_i16_clamped())
        try test.eq(I16(0x7FFF), Int(0x7FFF).to_i16_clamped())
        try test.eq(I16(-0x8000), Int(-0x8000).to_i16_clamped())
        try test.eq(I16(0x7FFF), Int(0x8000).to_i16_clamped())
        try test.eq(I16(-0x8000), Int(-0x8001).to_i16_clamped())
    })
    clamped_suite.test("Int.to_i32_clamped", fun() !void {
        try test.eq(I32(0), Int(0).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), Int(0x7FFF_FFFF).to_i32_clamped())
        try test.eq(I32(-0x8000_0000), Int(-0x8000_0000).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), Int(0x8000_0000).to_i32_clamped())
        try test.eq(I32(-0x8000_0000), Int(-0x8000_0001).to_i32_clamped())
    })
    --- Unsigned narrowing clamped ---
    clamped_suite.test("U16.to_u8_clamped", fun() !void {
        try test.eq(U8(0), U16(0).to_u8_clamped())
        try test.eq(U8(0xFF), U16(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), U16(0x100).to_u8_clamped())
        try test.eq(U8(0xFF), U16(0xFFFF).to_u8_clamped())
    })
    clamped_suite.test("U32.to_u8_clamped", fun() !void {
        try test.eq(U8(0), U32(0).to_u8_clamped())
        try test.eq(U8(0xFF), U32(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), U32(0x100).to_u8_clamped())
    })
    clamped_suite.test("U64.to_u8_clamped", fun() !void {
        try test.eq(U8(0), U64(0).to_u8_clamped())
        try test.eq(U8(0xFF), U64(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), U64(0x100).to_u8_clamped())
    })
    clamped_suite.test("U32.to_u16_clamped", fun() !void {
        try test.eq(U16(0), U32(0).to_u16_clamped())
        try test.eq(U16(0xFFFF), U32(0xFFFF).to_u16_clamped())
        try test.eq(U16(0xFFFF), U32(0x1_0000).to_u16_clamped())
    })
    clamped_suite.test("U64.to_u16_clamped", fun() !void {
        try test.eq(U16(0), U64(0).to_u16_clamped())
        try test.eq(U16(0xFFFF), U64(0xFFFF).to_u16_clamped())
        try test.eq(U16(0xFFFF), U64(0x1_0000).to_u16_clamped())
    })
    clamped_suite.test("U64.to_u32_clamped", fun() !void {
        try test.eq(U32(0), U64(0).to_u32_clamped())
        try test.eq(U32(0xFFFF_FFFF), U64(0xFFFF_FFFF).to_u32_clamped())
        try test.eq(U32(0xFFFF_FFFF), U64(0x1_0000_0000).to_u32_clamped())
    })
    --- Unsigned to signed clamped ---
    clamped_suite.test("U8.to_i8_clamped", fun() !void {
        try test.eq(I8(0), U8(0).to_i8_clamped())
        try test.eq(I8(0x7F), U8(0x7F).to_i8_clamped())
        try test.eq(I8(0x7F), U8(0x80).to_i8_clamped())
        try test.eq(I8(0x7F), U8(0xFF).to_i8_clamped())
    })
    clamped_suite.test("U16.to_i16_clamped", fun() !void {
        try test.eq(I16(0), U16(0).to_i16_clamped())
        try test.eq(I16(0x7FFF), U16(0x7FFF).to_i16_clamped())
        try test.eq(I16(0x7FFF), U16(0x8000).to_i16_clamped())
    })
    clamped_suite.test("U16.to_i8_clamped", fun() !void {
        try test.eq(I8(0), U16(0).to_i8_clamped())
        try test.eq(I8(0x7F), U16(0x7F).to_i8_clamped())
        try test.eq(I8(0x7F), U16(0x80).to_i8_clamped())
        try test.eq(I8(0x7F), U16(0xFFFF).to_i8_clamped())
    })
    clamped_suite.test("U32.to_i32_clamped", fun() !void {
        try test.eq(I32(0), U32(0).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), U32(0x7FFF_FFFF).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), U32(0x8000_0000).to_i32_clamped())
    })
    clamped_suite.test("U32.to_i16_clamped", fun() !void {
        try test.eq(I16(0), U32(0).to_i16_clamped())
        try test.eq(I16(0x7FFF), U32(0x7FFF).to_i16_clamped())
        try test.eq(I16(0x7FFF), U32(0x8000).to_i16_clamped())
    })
    clamped_suite.test("U32.to_i8_clamped", fun() !void {
        try test.eq(I8(0), U32(0).to_i8_clamped())
        try test.eq(I8(0x7F), U32(0x7F).to_i8_clamped())
        try test.eq(I8(0x7F), U32(0x80).to_i8_clamped())
    })
    clamped_suite.test("U64.to_int_clamped", fun() !void {
        try test.eq(Int(0), U64(0).to_int_clamped())
        try test.eq(Int(0x7FFF_FFFF_FFFF_FFFF), U64(0x7FFF_FFFF_FFFF_FFFF).to_int_clamped())
        try test.eq(Int(0x7FFF_FFFF_FFFF_FFFF), U64(0x8000_0000_0000_0000).to_int_clamped())
        try test.eq(Int(0x7FFF_FFFF_FFFF_FFFF), U64(0xFFFF_FFFF_FFFF_FFFF).to_int_clamped())
    })
    clamped_suite.test("U64.to_i32_clamped", fun() !void {
        try test.eq(I32(0), U64(0).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), U64(0x7FFF_FFFF).to_i32_clamped())
        try test.eq(I32(0x7FFF_FFFF), U64(0x8000_0000).to_i32_clamped())
    })
    --- Signed to unsigned clamped ---
    clamped_suite.test("I8.to_u8_clamped", fun() !void {
        try test.eq(U8(0), I8(0).to_u8_clamped())
        try test.eq(U8(0x7F), I8(0x7F).to_u8_clamped())
        try test.eq(U8(0), I8(-1).to_u8_clamped())
        try test.eq(U8(0), I8(-0x80).to_u8_clamped())
    })
    clamped_suite.test("I8.to_u16_clamped", fun() !void {
        try test.eq(U16(0), I8(0).to_u16_clamped())
        try test.eq(U16(0x7F), I8(0x7F).to_u16_clamped())
        try test.eq(U16(0), I8(-1).to_u16_clamped())
    })
    clamped_suite.test("I8.to_u32_clamped", fun() !void {
        try test.eq(U32(0), I8(0).to_u32_clamped())
        try test.eq(U32(0x7F), I8(0x7F).to_u32_clamped())
        try test.eq(U32(0), I8(-1).to_u32_clamped())
    })
    clamped_suite.test("I8.to_u64_clamped", fun() !void {
        try test.eq(U64(0), I8(0).to_u64_clamped())
        try test.eq(U64(0x7F), I8(0x7F).to_u64_clamped())
        try test.eq(U64(0), I8(-1).to_u64_clamped())
    })
    clamped_suite.test("I16.to_u8_clamped", fun() !void {
        try test.eq(U8(0), I16(0).to_u8_clamped())
        try test.eq(U8(0xFF), I16(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), I16(0x100).to_u8_clamped())
        try test.eq(U8(0), I16(-1).to_u8_clamped())
    })
    clamped_suite.test("I16.to_u16_clamped", fun() !void {
        try test.eq(U16(0), I16(0).to_u16_clamped())
        try test.eq(U16(0x7FFF), I16(0x7FFF).to_u16_clamped())
        try test.eq(U16(0), I16(-1).to_u16_clamped())
    })
    clamped_suite.test("I16.to_u32_clamped", fun() !void {
        try test.eq(U32(0), I16(0).to_u32_clamped())
        try test.eq(U32(0x7FFF), I16(0x7FFF).to_u32_clamped())
        try test.eq(U32(0), I16(-1).to_u32_clamped())
    })
    clamped_suite.test("I16.to_u64_clamped", fun() !void {
        try test.eq(U64(0), I16(0).to_u64_clamped())
        try test.eq(U64(0x7FFF), I16(0x7FFF).to_u64_clamped())
        try test.eq(U64(0), I16(-1).to_u64_clamped())
    })
    clamped_suite.test("I32.to_u8_clamped", fun() !void {
        try test.eq(U8(0), I32(0).to_u8_clamped())
        try test.eq(U8(0xFF), I32(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), I32(0x100).to_u8_clamped())
        try test.eq(U8(0), I32(-1).to_u8_clamped())
    })
    clamped_suite.test("I32.to_u16_clamped", fun() !void {
        try test.eq(U16(0), I32(0).to_u16_clamped())
        try test.eq(U16(0xFFFF), I32(0xFFFF).to_u16_clamped())
        try test.eq(U16(0xFFFF), I32(0x1_0000).to_u16_clamped())
        try test.eq(U16(0), I32(-1).to_u16_clamped())
    })
    clamped_suite.test("I32.to_u32_clamped", fun() !void {
        try test.eq(U32(0), I32(0).to_u32_clamped())
        try test.eq(U32(0x7FFF_FFFF), I32(0x7FFF_FFFF).to_u32_clamped())
        try test.eq(U32(0), I32(-1).to_u32_clamped())
    })
    clamped_suite.test("I32.to_u64_clamped", fun() !void {
        try test.eq(U64(0), I32(0).to_u64_clamped())
        try test.eq(U64(0x7FFF_FFFF), I32(0x7FFF_FFFF).to_u64_clamped())
        try test.eq(U64(0), I32(-1).to_u64_clamped())
    })
    clamped_suite.test("Int.to_u8_clamped", fun() !void {
        try test.eq(U8(0), Int(0).to_u8_clamped())
        try test.eq(U8(0xFF), Int(0xFF).to_u8_clamped())
        try test.eq(U8(0xFF), Int(0x100).to_u8_clamped())
        try test.eq(U8(0), Int(-1).to_u8_clamped())
    })
    clamped_suite.test("Int.to_u16_clamped", fun() !void {
        try test.eq(U16(0), Int(0).to_u16_clamped())
        try test.eq(U16(0xFFFF), Int(0xFFFF).to_u16_clamped())
        try test.eq(U16(0xFFFF), Int(0x1_0000).to_u16_clamped())
        try test.eq(U16(0), Int(-1).to_u16_clamped())
    })
    clamped_suite.test("Int.to_u32_clamped", fun() !void {
        try test.eq(U32(0), Int(0).to_u32_clamped())
        try test.eq(U32(0xFFFF_FFFF), Int(0xFFFF_FFFF).to_u32_clamped())
        try test.eq(U32(0xFFFF_FFFF), Int(0x1_0000_0000).to_u32_clamped())
        try test.eq(U32(0), Int(-1).to_u32_clamped())
    })
    clamped_suite.test("Int.to_u64_clamped", fun() !void {
        try test.eq(U64(0), Int(0).to_u64_clamped())
        try test.eq(U64(0x7FFF_FFFF_FFFF_FFFF), Int(0x7FFF_FFFF_FFFF_FFFF).to_u64_clamped())
        try test.eq(U64(0), Int(-1).to_u64_clamped())
    })
    _ = clamped_suite.run()

    let from_ascii_str_suite = test.Suite.new("from_ascii_str", @local)
    from_ascii_str_suite.test("I8.from_ascii_str", fun() !void {
        try test.eq(Result(I8(0x7F)), I8.from_ascii_str("127".as_bytes()))
        try test.eq(Result(I8(-0x80)), I8.from_ascii_str("-128".as_bytes()))
        try test.err(I8.from_ascii_str("128".as_bytes()), "parse error: number out of range")
        try test.err(I8.from_ascii_str("-129".as_bytes()), "parse error: number out of range")
    })
    from_ascii_str_suite.test("I16.from_ascii_str", fun() !void {
        try test.eq(Result(I16(0x7FFF)), I16.from_ascii_str("32767".as_bytes()))
        try test.eq(Result(I16(-0x8000)), I16.from_ascii_str("-32768".as_bytes()))
        try test.err(I16.from_ascii_str("32768".as_bytes()), "parse error: number out of range")
        try test.err(I16.from_ascii_str("-32769".as_bytes()), "parse error: number out of range")
    })
    from_ascii_str_suite.test("I32.from_ascii_str", fun() !void {
        try test.eq(Result(I32(0x7FFF_FFFF)), I32.from_ascii_str("2147483647".as_bytes()))
        try test.eq(Result(I32(-0x8000_0000)), I32.from_ascii_str("-2147483648".as_bytes()))
        try test.err(I32.from_ascii_str("2147483648".as_bytes()), "parse error: number out of range")
        try test.err(I32.from_ascii_str("-2147483649".as_bytes()), "parse error: number out of range")
    })
    from_ascii_str_suite.test("U8.from_ascii_str", fun() !void {
        try test.eq(Result(U8(0)), U8.from_ascii_str("0".as_bytes()))
        try test.eq(Result(U8(0xFF)), U8.from_ascii_str("255".as_bytes()))
        try test.err(U8.from_ascii_str("256".as_bytes()), "parse error: number out of range")
        try test.err(U8.from_ascii_str("-1".as_bytes()), "parse error: not a valid digit")
    })
    from_ascii_str_suite.test("U16.from_ascii_str", fun() !void {
        try test.eq(Result(U16(0)), U16.from_ascii_str("0".as_bytes()))
        try test.eq(Result(U16(0xFFFF)), U16.from_ascii_str("65535".as_bytes()))
        try test.err(U16.from_ascii_str("65536".as_bytes()), "parse error: number out of range")
        try test.err(U16.from_ascii_str("-1".as_bytes()), "parse error: not a valid digit")
