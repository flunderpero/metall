        try test.eq(Result(U64(2882400009)), U64.from_ascii_str("abcdef09".as_bytes(), 16))
        try test.eq(Result(U64(18446744073709551615)), U64.from_ascii_str("ffffffffffffffff".as_bytes(), 16))
        try test.err(U64.from_ascii_str("10000000000000000".as_bytes(), 16), "parse error: number out of range")
        try test.err(U64.from_ascii_str("g".as_bytes(), 16), "parse error: not a valid digit")
