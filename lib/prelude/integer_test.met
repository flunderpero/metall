            "parse error: number out of range")
        try test.err(U64.from_ascii_str("2".as_bytes(), 2), "parse error: not a valid digit")
        try test.err(U64.from_ascii_str("3".as_bytes(), 2), "parse error: not a valid digit")
    })
    _ = from_ascii_str_suite.run()
