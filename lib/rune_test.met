use std::test
use assert_ = std::assert

fun main() void {
    let @local = Arena()

    let suite = test::suite("Rune", @local)
    suite.test("from_u32_lossy", fun(assert &assert_::Assert) !void {
        try assert.eq('A', Rune.from_u32_lossy(65))
        try assert.eq('\u{FFFD}', Rune.from_u32_lossy(123456789))
        try assert.eq('\u{FFFD}', Rune.from_u32_lossy(55296)) -- 0xD800
    })
    suite.test("from_u32_checked", fun(assert &assert_::Assert) !void {
        try assert.eq(Result('A'), Rune.from_u32_checked(65))
        try assert.err(Rune.from_u32_checked(123456789), "rune out of range")
        try assert.err(Rune.from_u32_checked(55296), "rune in invalid surrogate range") -- 0xD800
    })
    suite.test("is_ascii_whitespace", fun(assert &assert_::Assert) !void {
        try assert.eq(true, ' '.is_ascii_whitespace())
        try assert.eq(true, '\n'.is_ascii_whitespace())
        try assert.eq(true, '\t'.is_ascii_whitespace())
        try assert.eq(true, '\r'.is_ascii_whitespace())
        try assert.eq(true, '\x0C'.is_ascii_whitespace())
        try assert.eq(false, 'a'.is_ascii_whitespace())
    })
    suite.test("is_ascii_lower", fun(assert &assert_::Assert) !void {
        try assert.eq(true, 'a'.is_ascii_lower())
        try assert.eq(true, 'z'.is_ascii_lower())
        try assert.eq(false, 'A'.is_ascii_lower())
        try assert.eq(false, 'Z'.is_ascii_lower())
        try assert.eq(false, ' '.is_ascii_lower())
    })
    suite.test("is_ascii_upper", fun(assert &assert_::Assert) !void {
        try assert.eq(true, 'A'.is_ascii_upper())
        try assert.eq(true, 'Z'.is_ascii_upper())
        try assert.eq(false, 'a'.is_ascii_upper())
        try assert.eq(false, 'z'.is_ascii_upper())
        try assert.eq(false, ' '.is_ascii_upper())
    })
    suite.test("is_ascii_digit", fun(assert &assert_::Assert) !void {
        try assert.eq(true, '0'.is_ascii_digit())
        try assert.eq(true, '5'.is_ascii_digit())
        try assert.eq(true, '9'.is_ascii_digit())
        try assert.eq(false, 'A'.is_ascii_digit())
        try assert.eq(false, 'Z'.is_ascii_digit())
        try assert.eq(false, 'a'.is_ascii_digit())
        try assert.eq(false, 'z'.is_ascii_digit())
        try assert.eq(false, ' '.is_ascii_digit())
    })
    suite.test("is_ascii_alpha", fun(assert &assert_::Assert) !void {
        try assert.eq(false, ' '.is_ascii_alpha())
        try assert.eq(false, '0'.is_ascii_alpha())
        try assert.eq(false, '9'.is_ascii_alpha())
        try assert.eq(true, 'A'.is_ascii_alpha())
        try assert.eq(true, 'Z'.is_ascii_alpha())
        try assert.eq(true, 'a'.is_ascii_alpha())
        try assert.eq(true, 'z'.is_ascii_alpha())
    })
    suite.test("is_ascii_alphanumeric", fun(assert &assert_::Assert) !void {
        try assert.eq(false, ' '.is_ascii_alphanumeric())
        try assert.eq(true, '0'.is_ascii_alphanumeric())
        try assert.eq(true, '9'.is_ascii_alphanumeric())
        try assert.eq(true, 'A'.is_ascii_alphanumeric())
        try assert.eq(true, 'Z'.is_ascii_alphanumeric())
        try assert.eq(true, 'a'.is_ascii_alphanumeric())
        try assert.eq(true, 'z'.is_ascii_alphanumeric())
    })
    suite.test("is_whitespace", fun(assert &assert_::Assert) !void {
        try assert.eq(true, ' '.is_whitespace())
        try assert.eq(true, '\n'.is_whitespace())
        try assert.eq(true, '\t'.is_whitespace())
        try assert.eq(true, '\r'.is_whitespace())
        try assert.eq(true, '\x0C'.is_whitespace())
        try assert.eq(false, 'a'.is_whitespace())
    })
    suite.test("is_lower", fun(assert &assert_::Assert) !void {
        try assert.eq(true, 'a'.is_lower())
        try assert.eq(true, 'z'.is_lower())
        try assert.eq(false, 'A'.is_lower())
        try assert.eq(false, 'Z'.is_lower())
        try assert.eq(false, ' '.is_lower())
    })
    suite.test("is_upper", fun(assert &assert_::Assert) !void {
        try assert.eq(true, 'A'.is_upper())
        try assert.eq(true, 'Z'.is_upper())
        try assert.eq(false, 'a'.is_upper())
        try assert.eq(false, 'z'.is_upper())
        try assert.eq(false, ' '.is_upper())
    })
    suite.test("is_digit", fun(assert &assert_::Assert) !void {
        try assert.eq(true, '0'.is_digit())
        try assert.eq(true, '5'.is_digit())
        try assert.eq(true, '9'.is_digit())
        try assert.eq(false, 'A'.is_digit())
        try assert.eq(false, 'Z'.is_digit())
        try assert.eq(false, 'a'.is_digit())
        try assert.eq(false, 'z'.is_digit())
        try assert.eq(false, ' '.is_digit())
    })
    suite.test("is_alpha", fun(assert &assert_::Assert) !void {
        try assert.eq(false, ' '.is_alpha())
        try assert.eq(false, '0'.is_alpha())
        try assert.eq(false, '9'.is_alpha())
        try assert.eq(true, 'A'.is_alpha())
        try assert.eq(true, 'Z'.is_alpha())
        try assert.eq(true, 'a'.is_alpha())
        try assert.eq(true, 'z'.is_alpha())
    })
    suite.test("is_alphanumeric", fun(assert &assert_::Assert) !void {
        try assert.eq(false, ' '.is_alphanumeric())
        try assert.eq(true, '0'.is_alphanumeric())
        try assert.eq(true, '9'.is_alphanumeric())
        try assert.eq(true, 'A'.is_alphanumeric())
        try assert.eq(true, 'Z'.is_alphanumeric())
        try assert.eq(true, 'a'.is_alphanumeric())
        try assert.eq(true, 'z'.is_alphanumeric())
    })
    _ = suite.run()
}
