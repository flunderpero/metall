--- A placeholder type for the builtin `Float` type.

    Has no `hash`, so it is not a valid `map.Key`: IEEE `eq` makes a NaN key
    unequal to itself, which a hash table cannot store or retrieve. Key on
    `f.to_bits()` instead. ---
pub struct Float {}

pub fun Float.to_f32(self Float) F32 {}
pub fun Float.to_int_clamped(self Float) Int {}
pub fun Float.is_nan(self Float) Bool {}
pub fun Float.is_inf(self Float) Bool {}
pub fun Float.to_bits(self Float) U64 {}
pub fun Float.from_bits(bits U64) Float {}

--- A placeholder type for the builtin `F32` type.

    Has no `hash`, so it is not a valid `map.Key`: IEEE `eq` makes a NaN key
    unequal to itself, which a hash table cannot store or retrieve. Key on
    `f.to_bits()` instead. ---
pub struct F32 {}

pub fun F32.to_float(self F32) Float {}
pub fun F32.to_int_clamped(self F32) Int {}
pub fun F32.is_nan(self F32) Bool {}
pub fun F32.is_inf(self F32) Bool {}
pub fun F32.to_bits(self F32) U32 {}
pub fun F32.from_bits(bits U32) F32 {}

