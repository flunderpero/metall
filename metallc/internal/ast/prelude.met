fun Int.to_u16_clamped(i Int) U16 { if i < 0 { return 0 } if i > 65535 { return 65535 } i.to_u16_wrapping() }
fun Int.to_u32_clamped(i Int) U32 { if i < 0 { return 0 } if i > 4294967295 { return 4294967295 } i.to_u32_wrapping() }
fun Int.to_u64_clamped(i Int) U64 { if i < 0 { return 0 } i.to_u64_wrapping() }

fun Int.from_ascii_str(str []U8, base Int = 10) !Int {
    mut s = str[..]
    let negate = if s[0] == 45 {
        if s.len == 1 {
            return Err("parse error: '-' must be followed by digits")
        }
        s = s[1..]
        true
    } else { false }
    mut result = try U64.from_ascii_str(s, base)
    if negate {
        if result > 9223372036854775808 {
            return Err("parse error: number out of range")
        }
        if result == 9223372036854775808 {
            -9223372036854775808
        } else {
            0 - result.to_int_wrapping()
        }
    } else {
        if result >= 9223372036854775808 {
            return Err("parse error: number out of range")
        }
        result.to_int_wrapping()
    }
}

fun U64.from_ascii_str(s []U8, base Int = 10) !U64 {
    if base != 2 and base != 8 and base != 10 and base != 16 {
        panic("invalid base")
    }
    if s.len == 0 {
        return Err("parse error: empty slice")
    }
    let base_u64 = base.to_u64_wrapping()
    mut result U64 = 0
    for i in 0..s.len {
        mut digit = s[i].to_u64()
        if base_u64 == 16 {
            if digit >= 65 and digit <= 70 {
                digit = digit - 55
            } else {
                if (digit >= 97 and digit <= 102) {
                    digit = digit - 87
                } else {
                    if digit < 48 or digit > 57 {
                        return Err("parse error: not a valid digit")
                    }
                    digit = digit - 48
                }
            }
        } else {
            if digit < 48 or digit >= base_u64 + 48 {
                return Err("parse error: not a valid digit")
            }
            digit = digit - 48
        }
        let result_before = result
        if result > (U64(18446744073709551615) - digit) / base_u64 {
             return Err("parse error: number out of range")
        }
        result = result *% base_u64 +% digit
    }
    result
}

fun I8.from_ascii_str(s []U8, base Int = 10) !I8 {
    try (try Int.from_ascii_str(s, base)).to_i8_checked() else { return Err("parse error: number out of range") }
}
fun I16.from_ascii_str(s []U8, base Int = 10) !I16 {
    try (try Int.from_ascii_str(s, base)).to_i16_checked() else { return Err("parse error: number out of range") }
}
fun I32.from_ascii_str(s []U8, base Int = 10) !I32 {
    try (try Int.from_ascii_str(s, base)).to_i32_checked() else { return Err("parse error: number out of range") }
}
fun U8.from_ascii_str(s []U8, base Int = 10) !U8 {
    try (try U64.from_ascii_str(s, base)).to_u8_checked() else { return Err("parse error: number out of range") }
}
fun U16.from_ascii_str(s []U8, base Int = 10) !U16 {
    try (try U64.from_ascii_str(s, base)).to_u16_checked() else { return Err("parse error: number out of range") }
}
fun U32.from_ascii_str(s []U8, base Int = 10) !U32 {
    try (try U64.from_ascii_str(s, base)).to_u32_checked() else { return Err("parse error: number out of range") }
}
