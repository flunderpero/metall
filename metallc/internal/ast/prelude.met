fun U8.hash(u U8) U64 { u.to_u64() *% 5871781006564002453 }
fun U16.hash(u U16) U64 { u.to_u64() *% 5871781006564002453 }
fun U32.hash(u U32) U64 { u.to_u64() *% 5871781006564002453 }
fun U64.hash(u U64) U64 { u *% 5871781006564002453 }
fun Rune.hash(r Rune) U64 { r.to_u32().to_u64() *% 5871781006564002453 }
fun Bool.hash(b Bool) U64 { if b { 1 } else { 0 } }
