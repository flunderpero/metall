run *args:
    set -euo pipefail
    mkdir -p .build
    go run ../metallc/... build -I ../lib --opt fast -o .build/run run.met
    ./.build/run {{args}}

# Run the full benchmark suite over 5 loops and record the (de-colored) output to results.txt.
record:
    #!/usr/bin/env bash
    just run --loops 5 | tee >(perl -pe 's/\x1b\[[0-9;]*[A-Za-z]//g' > results.txt)

compile-check:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ">>> Compile-check benchmarks"
    mkdir -p .build
    for file in *.met; do
        echo "    $file"
        go run ../metallc/... build -I ../lib --opt fast -o ".build/${file%.met}" "$file"
    done
