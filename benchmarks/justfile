all *args:
    mkdir -p .build
    go run ../metallc/... build -I ../lib --opt fast -o .build/run run.met
    ./.build/run {{args}}

compile-check:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ">>> Compile-check benchmarks"
    mkdir -p .build
    for file in *.met; do
        echo "    $file"
        go run ../metallc/... build -I ../lib --opt fast -o ".build/${file%.met}" "$file"
    done
